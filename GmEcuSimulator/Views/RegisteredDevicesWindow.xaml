<Window x:Class="GmEcuSimulator.Views.RegisteredDevicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registered J2534 Devices" Height="520" Width="820"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" TextWrapping="Wrap"
                   Text="Output of Installer\List.ps1 — every J2534 PassThru device registered on this machine, both bitnesses. Read-only diagnostic."/>
        <Button DockPanel.Dock="Bottom" HorizontalAlignment="Right" Padding="16,4" Margin="0,8,0,0"
                Content="Close" IsCancel="True" IsDefault="True" Click="OnCloseClicked"/>
        <TextBox x:Name="OutputBox"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Background="#FAFAFA"/>
    </DockPanel>
</Window>
