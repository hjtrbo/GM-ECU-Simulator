<Window x:Class="GmEcuSimulator.Views.EcuSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GmEcuSimulator.Converters"
        xmlns:local="clr-namespace:GmEcuSimulator.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:proto="clr-namespace:Common.Protocol;assembly=EcuSim.Common"
        xmlns:wave="clr-namespace:Common.Waveforms;assembly=EcuSim.Common"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="av"
        Title="ECU Editor"
        Icon="/Resources/app.ico"
        Height="720" Width="1100"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ShowInTaskbar="True"
        FontSize="14"
        Style="{StaticResource Window.AppShell}">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Material Design merge moved to the PID DataGrid's local
                 Resources (search for "DataGrid.Resources" below) so the
                 BundledTheme's implicit Button / TextBox / ComboBox styles
                 stay scoped to the grid itself. Without that scoping the
                 implicit styles bled out to the toolbar Save / Load / Add /
                 Delete icon buttons, repainting them in Material Teal /
                 DeepOrange instead of the GMThemeManager palette. -->

        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PidModeDisplayConverter   x:Key="PidModeDisplay"/>

        <!-- Validation error template + implicit TextBox style. Duplicated
             from MainWindow so validation rendering is consistent between
             windows. Keeping them per-window avoids a wider App.xaml refactor. -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder">
                    <Border BorderBrush="#E04848" BorderThickness="1"/>
                </AdornedElementPlaceholder>
            </StackPanel>
        </ControlTemplate>

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Same enum providers used by MainWindow. FileStream is omitted on
             purpose; bin-stream PIDs adopt it internally - the user picks
             from this list. -->
        <x:Array x:Key="WaveformShapes" Type="{x:Type wave:WaveformShape}">
            <wave:WaveformShape>Sin</wave:WaveformShape>
            <wave:WaveformShape>Triangle</wave:WaveformShape>
            <wave:WaveformShape>Square</wave:WaveformShape>
            <wave:WaveformShape>Sawtooth</wave:WaveformShape>
            <wave:WaveformShape>CsvFile</wave:WaveformShape>
            <wave:WaveformShape>Constant</wave:WaveformShape>
        </x:Array>
        <ObjectDataProvider x:Key="CsvLoopModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="wave:CsvLoopMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PidSizes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="proto:PidSize"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PidDataTypes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="proto:PidDataType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PidModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="proto:PidMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Caption styles in the theme set a smaller FontSize that would
             override window-level inheritance; pin to 14 locally. Same
             pattern as the Prime Wizard pages. -->
        <Style x:Key="Caption14" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="Hint14" TargetType="TextBlock" BasedOn="{StaticResource Text.Hint}">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Mode-section ($01 / $1A / $22 / $2D) Expander header. The stock Expander
             header presenter renders a plain string in the system default colour
             (black, invisible on the dark theme), so we supply a HeaderTemplate that
             paints the header with the active theme's primary text brush. The
             template DataContext is the header string itself. -->
        <DataTemplate x:Key="ModeSectionHeader">
            <TextBlock Text="{Binding}"
                       Foreground="{DynamicResource Text.PrimaryBrush}"
                       FontWeight="SemiBold"
                       FontSize="15"/>
        </DataTemplate>

        <!-- Subtle 1px divider between mode sections, using the theme's subtle
             border brush so it tracks the active palette. -->
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Border.SubtleBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Excel-style column header. DataContext is the column's PidColumnFilter
             (set via the column's Header binding). Shows the title, a magnifying
             glass when a filter is active, and a right-click popup with sort
             asc/desc, a filter box, and clear. Right-click is handled in
             EcuSetupWindow.xaml.cs (OnColumnHeaderRightClick), which opens the popup
             by setting the filter's IsOpen. -->
        <DataTemplate x:Key="PidColumnHeader">
            <Grid Background="Transparent"
                  HorizontalAlignment="Stretch"
                  MouseRightButtonUp="OnColumnHeaderRightClick"
                  ToolTip="Right-click to sort or filter this column.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                <!-- Indicators: sort arrow (+ priority number when more than one
                     column is sorted) then the active-filter magnifying glass. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SortGlyph}"
                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Margin="6,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource Accent.PrimaryBrush}"
                               Visibility="{Binding IsSorted, Converter={StaticResource BoolToVis}}"
                               ToolTip="This column is part of the sort order."/>
                    <TextBlock Text="{Binding SortPriorityText}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="1,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource Accent.PrimaryBrush}"
                               Visibility="{Binding ShowSortPriority, Converter={StaticResource BoolToVis}}"
                               ToolTip="Sort priority (1 = primary key)."/>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Margin="6,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource Accent.PrimaryBrush}"
                               Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"
                               ToolTip="A filter is active on this column."/>
                </StackPanel>
                <Popup Grid.Column="0" Grid.ColumnSpan="2"
                       IsOpen="{Binding IsOpen}"
                       StaysOpen="False"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Style="{StaticResource Card}" MinWidth="220" Margin="0,4,0,0">
                        <StackPanel>
                            <Button Content="Sort Ascending"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding SortAscendingCommand}"
                                    Margin="0,0,0,4"/>
                            <Button Content="Sort Descending"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding SortDescendingCommand}"
                                    Margin="0,0,0,4"/>
                            <!-- Removes just this column from the multi-level sort;
                                 hidden until the column is actually sorted. -->
                            <Button Content="Clear Sort"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding ClearSortCommand}"
                                    Visibility="{Binding IsSorted, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,8"/>
                            <Separator Margin="0,0,0,8"/>
                            <TextBlock Text="Filter" Style="{StaticResource Caption14}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32" VerticalContentAlignment="Center"/>
                            <Button Content="Clear Filter"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding ClearFilterCommand}"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Custom titlebar matching the main shell. -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <Border Width="18" Height="18" CornerRadius="3"
                        Background="{DynamicResource Accent.PrimaryBrush}"
                        Margin="0,0,8,0">
                    <TextBlock Text="G" Foreground="White"
                               FontFamily="{StaticResource Font.SansDisplay}"
                               FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="ECU Editor"
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Text.PrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="MinimizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMinimizeClicked"
                        ToolTip="Minimize">
                    <Path Data="{StaticResource Icon.Minimize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="MaximizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMaximizeClicked"
                        ToolTip="Maximize">
                    <Path x:Name="MaxIcon"
                          Data="{StaticResource Icon.Maximize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="CloseBtn"
                        Style="{StaticResource Button.ChromeClose}"
                        Click="OnCloseWindowClicked"
                        ToolTip="Close">
                    <Path Data="{StaticResource Icon.Close}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!--
            Three-pane editor (ECU list | PIDs | Waveform). Same layout as the
            workspace MainWindow used to host - lifted wholesale into this
            window so the user can edit PIDs / waveforms next to the main
            window's Selected ECU inspector.

            The ECU list here drives SetupSelectedEcu, not SelectedEcu, so
            picking a different ECU in this window does NOT disturb the main
            window's inspector.
        -->
        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <!-- ECU sidebar | splitter | PIDs main | Waveform inspector.
                     ECU sidebar default width reduced ~30 % from 240 -> 170;
                     MinWidth dropped to 100 so the user can shrink it further
                     via the inserted vertical GridSplitter when they want
                     more horizontal room for the PID grid. -->
                <ColumnDefinition Width="170" MinWidth="170"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"   MinWidth="320"/>
                <ColumnDefinition Width="260" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- ECU sidebar (independent selection: SetupSelectedEcu) -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ECUs" Style="{StaticResource Text.SectionHeader}"
                                   Margin="0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Ecus.Count, StringFormat=\{0\} configured}"
                                   Style="{StaticResource Caption14}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- ECU toolbar. Save / Load / Add / Remove operate on
                         SetupSelectedEcu (the list's local selection), not
                         the main window's SelectedEcu, so the buttons reflect
                         what the user has highlighted in this pane. Add /
                         Load reuse the main commands - they create a new ECU
                         regardless of which "selected" one is in focus. Save
                         / Remove route to the *Setup* variants so they target
                         the local selection. Glyphs match the MainWindow ECUs
                         header (Segoe MDL2 Assets save/load + Path strokes for
                         the +/-). -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Width="28" Height="22" Padding="0" Margin="0,0,6,0"
                                Command="{Binding SaveSetupEcuCommand}"
                                ToolTip="Save the selected ECU (CAN IDs, security module, PIDs, waveforms) to a *.ecu.json file.">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Width="28" Height="22" Padding="0" Margin="0,0,6,0"
                                Command="{Binding LoadEcuCommand}"
                                ToolTip="Load an ECU from a *.ecu.json file and add it to the bus.">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Width="28" Height="22" Padding="0" Margin="0,0,6,0"
                                Command="{Binding AddEcuCommand}"
                                ToolTip="Add a blank ECU at the next free OBD-II ID.">
                            <Path Data="M 0,5 L 10,5 M 5,0 L 5,10"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.4"
                                  Width="10" Height="10"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Width="28" Height="22" Padding="0"
                                Command="{Binding RemoveSetupEcuCommand}"
                                ToolTip="Remove the selected ECU from the bus. Prompts for confirmation.">
                            <Path Data="M 0,5 L 10,5"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.4"
                                  Width="10" Height="10"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Ecus}"
                             SelectedItem="{Binding SetupSelectedEcu}"
                             DisplayMemberPath="Name"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0" av:ItemsSource="{av:SampleData ItemCount=5}"/>
                </Grid>
            </Border>

            <!-- Vertical splitter between the ECU sidebar and the PIDs pane.
                 6 px wide, transparent body with a single-pixel divider so it
                 doesn't compete with the surrounding card chrome - matches the
                 horizontal EditorSplitter pattern in MainWindow.xaml. -->
            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Margin="6,0"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Border Background="Transparent">
                            <Rectangle Width="1" Fill="{DynamicResource Border.SubtleBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- PIDs main pane -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel DataContext="{Binding SetupSelectedEcu}" LastChildFill="True">
                    <!-- Selected-ECU header, relocated from the main window. Shows the ECU name
                         and the "Edit prime..." button (visible only for DPS-primed ECUs). ECU
                         rename itself lives in the relocated "ECU settings" section below (its
                         Name field), so the old standalone name editor that used to sit here was
                         removed to avoid two identical Name inputs stacked together. Binds to the
                         sidebar-selected ECU via the pane's inherited DataContext. -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Selected ECU"
                                   Style="{StaticResource Text.Subtitle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Style="{StaticResource Caption14}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <Button Grid.Column="2"
                                Content="Edit prime..."
                                Padding="10,4"
                                Command="{Binding EditPrimeCommand}"
                                Visibility="{Binding IsPrimed, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
                                ToolTip="Re-open the DPS Prime Wizard with this ECU's prior selections pre-filled. Replaces the ECU atomically on Apply."/>
                    </Grid>
                    <!-- Pane summary line. The Save / Load PIDs buttons used to live here, but flush
                         above the "ECU settings" form they read as acting on the ECU settings (CAN
                         IDs, engine model, scenario) - which they don't. They now sit in the
                         "Diagnostic PIDs" group header directly above the $1A/$22/$2D sections they
                         actually operate on. This row is now a pure parameter-count summary. -->
<!--                     <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PIDs"
                                   Style="{StaticResource Text.Subtitle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Pids.Count, FallbackValue=no ECU selected, StringFormat=\{0\} parameter(s)}"
                                   Style="{StaticResource Caption14}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </Grid> -->

                    <!-- All diagnostic modes as collapsible sections, scrolled vertically. The editable modes
                         ($1A / $22 / $2D) come from the Sections ItemsControl - one Expander + grid each, with its
                         own per-mode Add/Remove and its own Excel-style sort/filter column headers. The read-only
                         $01 (OBD-II) section follows. There is no longer a Mode column: a row's mode is the section
                         it lives in. Together these are the whole-ECU view. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <!-- Whole section stack is gated on an ECU being selected. The Sections ItemsControl collapses
                             on its own when its source is empty, but the three hardcoded Expanders (ECU settings / CAN
                             Broadcast / $01 (OBD-II)) inherit the pane's SetupSelectedEcu DataContext and would otherwise
                             render their empty grids with no ECU picked. Binding to the DataContext itself (no Path) with
                             ConverterParameter=NotNull collapses all of them when SetupSelectedEcu is null. -->
                        <StackPanel Visibility="{Binding ConverterParameter=NotNull, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <!-- ECU settings. The Selected-ECU inspector relocated out of the main window: identity
                                 (Name), the three CAN IDs, the programming-only FC.BS / Diag addr / Sec module fields,
                                 and the live-signal Scenario with its sweep knobs. Inherits the pane's DataContext
                                 (SetupSelectedEcu), so it tracks the ECU highlighted in the sidebar. Collapsible like the
                                 mode sections; starts expanded since it is the primary per-ECU configuration. The
                                 ShowsProgrammingFields / ShowsSecurityModuleReadOnly visibility bindings reach the
                                 MainViewModel via the window DataContext, exactly as they did in the main window. -->
                            <Expander Header="ECU settings" HeaderTemplate="{StaticResource ModeSectionHeader}"
                                      IsExpanded="True" Margin="0,0,0,10">
                                <WrapPanel Orientation="Horizontal">
                                    <WrapPanel.Resources>
                                        <!-- Each form cell is a fixed-width Grid so the WrapPanel can lay out 2 columns
                                             when room permits, 1 when narrow. 280px cell + 12px right gap = ~292px stride. -->
                                        <Style x:Key="FormCell" TargetType="Grid">
                                            <Setter Property="Width" Value="280"/>
                                            <Setter Property="Margin" Value="0,0,12,4"/>
                                        </Style>
                                    </WrapPanel.Resources>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Name"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Req CAN"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding PhysicalRequestCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="USDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UsdtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="UUDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UudtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsProgrammingFields, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="FC.BS"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding FlowControlBlockSizeHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="ISO 15765-2 FlowControl BlockSize (FC.BS). When this ECU receives a First Frame, it replies with FC = 30 BS 00. BS tells the tester how many Consecutive Frames to send before waiting for another FC: 0 = send all CFs in one burst (most permissive, works with most hosts); 1 = send 1 CF then wait for another FC, etc. Set BS=1 for the 6Speed.T43 tester - it sniffs the FC tail for the pattern '01' to recognise a T43 TCM and won't start the kernel upload otherwise."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsProgrammingFields, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Diag addr"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding DiagnosticAddressHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="4"
                                                 ToolTip="GMW3110 8-bit diagnostic address. For SPS type C this is the byte that derives SPS_PrimeReq ($000|addr) and SPS_PrimeRsp ($300|addr). e.g. $11 -> req $011, resp $311. Informational for type A/B (their CAN IDs are explicit)."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}"
                                          Visibility="{Binding DataContext.ShowsSecurityModuleReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Sec module"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding SelectedSecurityModuleId, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="Seed/key algorithm picked for this primed ECU. In DPS modes the Prime Wizard owns this choice - re-open the wizard (Edit primed) to change it."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Engine model"/>
                                        <ComboBox Grid.Column="1" Margin="0,2" Height="40"
                                                  ItemsSource="{Binding EngineModels}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding SelectedEngineModelId}"
                                                  ToolTip="The engine character driving this ECU's derived signals (induction, airflow, fuelling). Naturally Aspirated keeps MAP in vacuum (fuel pressure tops out at the 4 bar base); Boosted V8 drives MAP above barometric under load, so MAF and fuel pressure rise above base. Swaps live - a connected tool sees the change on the next read."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Scenario"/>
                                        <ComboBox Grid.Column="1" Margin="0,2" Height="40"
                                                  ItemsSource="{Binding Scenarios}"
                                                  SelectedItem="{Binding SelectedScenario}"
                                                  ToolTip="Operating point driving this ECU's live signals. Switching it ramps RPM, load, MAP, MAF, O2 etc. toward the new state - a connected tool sees Mode $01 and any signal-backed $22 PIDs move."/>
                                    </Grid>

                                    <!-- AccelDecelSweep timing is fixed at SweepProfile.Default; the per-ECU Sweep*
                                         editor inputs were retired (they were collapsed and no longer persisted). -->
                                </WrapPanel>
                            </Expander>
                            <Border Style="{StaticResource SectionDivider}"/>

                            <!-- CAN Broadcast: the DBC-driven unsolicited frames this ECU emits while a host session is
                                 open (the background traffic a passive logger sees). Sits above $01. Nested layout: an
                                 outer messages grid; selecting a message reveals its signals grid (row details) where
                                 each field maps to a live engine signal / constant. Import DBC / Save / Load reach the
                                 MainViewModel via the Window DataContext; Add / Remove message are EcuViewModel commands. -->
                            <Expander Header="CAN Broadcast" HeaderTemplate="{StaticResource ModeSectionHeader}"
                                      IsExpanded="False" Margin="0,0,0,10">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                                HorizontalAlignment="Right" Margin="0,0,0,6">
                                        <Button Content="Import DBC..." Padding="10,4" Margin="0,0,6,0"
                                                Command="{Binding DataContext.ImportDbcCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Parse a .dbc file, pick the transmitter + messages, and add them to this ECU's broadcast set."/>
                                        <Button Width="30" Height="26" Padding="0" Margin="0,0,6,0"
                                                Command="{Binding DataContext.SaveBroadcastsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Save this ECU's broadcast set to a *.dbc.json file.">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Width="30" Height="26" Padding="0" Margin="0,0,12,0"
                                                Command="{Binding DataContext.LoadBroadcastsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Load a *.dbc.json file and replace this ECU's broadcast set.">
                                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Width="30" Height="26" Padding="0" Margin="0,0,6,0"
                                                Command="{Binding AddBroadcastCommand}"
                                                ToolTip="Add a new broadcast message. Set its CAN ID, period and signals after.">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Width="30" Height="26" Padding="0"
                                                Command="{Binding RemoveBroadcastCommand}"
                                                ToolTip="Remove the selected broadcast message.">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Outer messages grid. Selecting a row reveals its signals via RowDetails. -->
                                    <DataGrid ItemsSource="{Binding Broadcasts}"
                                              SelectedItem="{Binding SelectedBroadcast}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserSortColumns="False"
                                              FontSize="14"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowDetailsVisibilityMode="Visible"
                                              MaxHeight="420">
                                        <!-- The details area is always present; its content collapses to zero height
                                             unless the row's IsExpanded is set via the chevron column, so a row opens and
                                             re-collapses on each chevron click (independent of selection). Binding the
                                             content's Visibility directly is reliable, unlike fighting the DataGrid's own
                                             per-row DetailsVisibility management. -->
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="30">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding ToggleExpandedCommand}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Padding="0" Cursor="Hand"
                                                                ToolTip="Show / hide this message's signals">
                                                            <TextBlock Text="{Binding ChevronGlyph}"
                                                                       FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridCheckBoxColumn Header="On" Width="44"
                                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                                            <DataGridTextColumn Header="CAN ID" Width="90"
                                                                Binding="{Binding CanIdHex, UpdateSourceTrigger=LostFocus}"
                                                                FontFamily="{StaticResource Font.Mono}"/>
                                            <DataGridTextColumn Header="Name" Width="*" MinWidth="120"
                                                                Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                                            <DataGridTextColumn Header="DLC" Width="56"
                                                                Binding="{Binding Dlc, UpdateSourceTrigger=LostFocus}"/>
                                            <DataGridTextColumn Header="Period (ms)" Width="92"
                                                                Binding="{Binding PeriodMs, UpdateSourceTrigger=LostFocus}"/>
                                            <DataGridTextColumn Header="Signals" Width="64" IsReadOnly="True"
                                                                Binding="{Binding SignalCount}"/>
                                        </DataGrid.Columns>

                                        <DataGrid.RowDetailsTemplate>
                                            <DataTemplate>
                                                <Border Margin="20,4,8,8" Padding="8" CornerRadius="4"
                                                        BorderBrush="{DynamicResource Border.SubtleBrush}" BorderThickness="1"
                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                    <DockPanel>
                                                        <!-- Signals come from the DBC; the editor maps each to a live
                                                             source but does not add or remove rows (re-import to change). -->
                                                        <DataGrid ItemsSource="{Binding Signals}"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  FontSize="13"
                                                                  HeadersVisibility="Column"
                                                                  GridLinesVisibility="Horizontal"
                                                                  MaxHeight="260">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Signal" Width="160"
                                                                                    Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Bit" Width="48"
                                                                                    Binding="{Binding StartBit, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Len" Width="48"
                                                                                    Binding="{Binding Length, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Ord" Width="64" IsReadOnly="True"
                                                                                    Binding="{Binding ByteOrderLabel}"/>
                                                                <DataGridTextColumn Header="Scale" Width="70"
                                                                                    Binding="{Binding Scale, StringFormat=G, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Offset" Width="64"
                                                                                    Binding="{Binding Offset, StringFormat=G, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Unit" Width="56"
                                                                                    Binding="{Binding Unit, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTemplateColumn Header="Source" Width="150">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding SourceOptions}"
                                                                                      DisplayMemberPath="Display"
                                                                                      SelectedItem="{Binding SelectedSource, UpdateSourceTrigger=PropertyChanged}"
                                                                                      ToolTip="Where this field's value comes from: (none)=0, Constant=the fixed value, or a live engine signal."/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="Const" Width="64"
                                                                                    Binding="{Binding Constant, StringFormat=G, UpdateSourceTrigger=LostFocus}"/>
                                                                <DataGridTextColumn Header="Live" Width="70" IsReadOnly="True"
                                                                                    Binding="{Binding LiveValue}"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </DataGrid.RowDetailsTemplate>
                                    </DataGrid>
                                </DockPanel>
                            </Expander>
                            <Border Style="{StaticResource SectionDivider}"/>

                            <!-- Group header for the diagnostic PID modes. The Save / Load PIDs buttons act on
                                 the whole $1A/$22/$2D PID list (the *.pids.json file). It heads the diagnostic-
                                 mode sections rather than living in the pane's top summary row, where flush above
                                 the ECU settings form the buttons read as acting on the ECU settings. $01 is
                                 read-only (legislated J1979 encoding), so the buttons don't touch it - hence the
                                 "$1A / $22 / $2D" qualifier. AncestorType=Window resolves the command DataContext
                                 back to MainViewModel, bypassing the inner SetupSelectedEcu DataContext rebased
                                 for the rest of this pane. -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Diagnostic PIDs"
                                           Style="{StaticResource Text.Subtitle}"
                                           VerticalAlignment="Center"/>
                                <!--<TextBlock Grid.Column="1"
                                           Text="$1A / $22 / $2D"
                                           Style="{StaticResource Caption14}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>-->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <StackPanel.Resources>
                                        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Width" Value="36"/>
                                            <Setter Property="Height" Value="32"/>
                                            <Setter Property="Margin" Value="0,0,6,0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </StackPanel.Resources>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.SavePidsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            ToolTip="Save this ECU's $1A/$22/$2D PID list (including waveform settings) to a .pids.json file. Does not include ECU settings or CAN broadcasts - use the sidebar's Save ECU for the whole ECU.">
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}"
                                            Margin="0"
                                            Command="{Binding DataContext.LoadPidsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            ToolTip="Load a .pids.json file and replace this ECU's $1A/$22/$2D PID list with its contents.">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Sections run lowest mode to highest: $01 first, then the editable $1A / $22 / $2D from
                                 the Sections ItemsControl. All start collapsed so a freshly-opened ECU isn't a wall of
                                 grids - the user expands the mode they want. -->
                            <!-- $01 (OBD-II): every J1979 catalogue PID this ECU can answer, read-only (the encoding
                                 is legislated) with a per-row "On" toggle that sets whether the ECU advertises it
                                 (drives the $00/$20 support bitmask). -->
                            <Expander Header="$01 (OBD-II)" HeaderTemplate="{StaticResource ModeSectionHeader}"
                                      IsExpanded="False" Margin="0,0,0,10">
                                <DataGrid ItemsSource="{Binding Obd2Pids}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserSortColumns="False"
                                          FontSize="14"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          MaxHeight="320">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="On" Width="44">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Supported, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              ToolTip="Advertise this $01 PID. Drives the $00/$20 support bitmask; unchecking makes a tester's request for it return NRC $31."/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="PID"   Binding="{Binding PidHex}"  Width="64"  IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="200" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Bytes"   Binding="{Binding Bytes}"   Width="60"  IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Raw"     Binding="{Binding RawHex}"  Width="84"  IsReadOnly="True"
                                                            FontFamily="{StaticResource Font.Mono}"/>
                                        <DataGridTextColumn Header="Decoded" Binding="{Binding Decoded}" Width="*" MinWidth="140" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>

                            <ItemsControl ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Divider above each editable section separates it from the one above
                                             ($01 from $1A, $1A from $22, $22 from $2D). -->
                                        <StackPanel>
                                            <Border Style="{StaticResource SectionDivider}"/>
                                            <Expander Header="{Binding Title}" HeaderTemplate="{StaticResource ModeSectionHeader}"
                                                      IsExpanded="False" Margin="0,0,0,10">
                                                <DockPanel>
                                                <!-- Per-mode toolbar: Add stamps THIS section's mode onto the new
                                                     row; Remove deletes this section's selected row. -->
                                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                                            HorizontalAlignment="Right" Margin="0,0,0,6">
                                                    <Button Width="30" Height="26" Padding="0" Margin="0,0,6,0"
                                                            Command="{Binding AddCommand}"
                                                            ToolTip="Add a new row to this mode. The address auto-picks the next free byte range; rename and re-point it after.">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Button>
                                                    <Button Width="30" Height="26" Padding="0"
                                                            Command="{Binding RemoveCommand}"
                                                            CommandParameter="{Binding SelectedItems, ElementName=SectionPidGrid}"
                                                            ToolTip="Remove the selected row(s) in this section. Ctrl/Shift-click to select multiple rows first.">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>

                                                <DataGrid x:Name="SectionPidGrid"
                                                          ItemsSource="{Binding View}"
                                                          SelectedItem="{Binding SelectedPid}"
                                                          AutoGenerateColumns="False"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          CanUserSortColumns="False"
                                                          SelectionMode="Extended"
                                                          SelectionUnit="FullRow"
                                                          FontSize="14"
                                                          HeadersVisibility="Column"
                                                          GridLinesVisibility="Horizontal"
                                                          MaxHeight="320">
                                                    <!-- All DataGrid chrome + in-cell editors come from
                                                         GMThemeManager's global DataGrid theme. Sorting/filtering is
                                                         Excel-style (right-click a header); each header binds to this
                                                         SECTION's PidColumnFilter objects through SecProxy, since a
                                                         DataGridColumn can't see the DataGrid's DataContext directly. -->
                                                    <DataGrid.Resources>
                                                        <local:BindingProxy x:Key="SecProxy" Data="{Binding}"/>
                                                    </DataGrid.Resources>
                                                    <DataGrid.RowStyle>
                                                        <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                                            <Style.Triggers>
                                                                <!-- $2D alias-collision warning (two Mode2D rows sharing the
                                                                     bottom 12 bits of address). Takes priority over the Nyquist
                                                                     warning because it indicates an unreachable row, not a
                                                                     display artefact. -->
                                                                <DataTrigger Binding="{Binding HasAliasCollision}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Status.ErrorBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                                                    <Setter Property="ToolTip" Value="{Binding AliasCollisionTooltip}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HasAliasWarning}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Status.ErrorBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                                                    <Setter Property="ToolTip" Value="{Binding AliasWarningTooltip}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGrid.RowStyle>
                                                    <DataGrid.Columns>
                                                        <!-- Identifier cell. $1A/$22 rows show a ComboBox picker bound to
                                                             the row's mode-specific PidCatalogue list; $2D rows show a
                                                             free-text hex input for the 32-bit memory address. Both
                                                             controls share the cell - exactly one is visible at a time. -->
                                                        <DataGridTemplateColumn Width="170"
                                                                                HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                                Header="{Binding Data.IdentifierColumnFilter, Source={StaticResource SecProxy}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <ComboBox Style="{StaticResource DataGrid.InCellComboBox}"
                                                                                  ItemsSource="{Binding IdentifierCatalogue}"
                                                                                  DisplayMemberPath="Display"
                                                                                  SelectedItem="{Binding SelectedCatalogueEntry, UpdateSourceTrigger=PropertyChanged}"
                                                                                  ToolTip="{Binding IdentifierLabel}"
                                                                                  Visibility="{Binding IsCatalogueDriven, Converter={StaticResource BoolToVis}}"/>
                                                                        <TextBox Style="{StaticResource DataGrid.InCellTextBox}"
                                                                                 Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"
                                                                                 Text="{Binding AddressHex, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}"
                                                                                 Visibility="{Binding IsHandRolled, Converter={StaticResource BoolToVis}}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <!-- Name is editable in every mode - even catalogue-driven rows can
                                                             carry a user-supplied label (e.g. "VIN (donor)" to distinguish
                                                             multiple ECUs). -->
                                                        <DataGridTextColumn Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"       Width="*" MinWidth="120"
                                                                            HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                            Header="{Binding Data.NameColumnFilter, Source={StaticResource SecProxy}}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"
                                                                            EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"/>
                                                        <!-- Value = the row's static response payload (what a bin load surfaces: VIN,
                                                             part numbers, ...). ASCII when printable, "0x..." hex otherwise. Edit as
                                                             text, or prefix "0x" to enter raw bytes; editing resizes the row to match. -->
                                                        <DataGridTextColumn Binding="{Binding ValueText, UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="170"
                                                                            Header="Value"
                                                                            Visibility="{Binding Data.IsNotMode22, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                            FontFamily="{StaticResource Font.Mono}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"
                                                                            EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"/>
                                                        <!-- Size = response length in bytes (1-99), free text. Drives Pid.LengthBytes so widths
                                                             beyond the old Byte/Word/DWord set work (a VIN is 17). Invalid input shows the row's
                                                             INotifyDataErrorInfo red border and leaves the model unchanged until corrected. -->
                                                        <DataGridTemplateColumn Width="84"
                                                                                HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                                Header="{Binding Data.SizeColumnFilter, Source={StaticResource SecProxy}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBox Style="{StaticResource DataGrid.InCellTextBox}"
                                                                             Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"
                                                                             Text="{Binding LengthBytesText, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}"
                                                                             IsReadOnly="{Binding Data.IsMode1A, Source={StaticResource SecProxy}}"
                                                                             ToolTip="Response length in bytes (1-99). E.g. a VIN is 17 bytes. Read-only for $1A - the identity value's length drives it."/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Width="96"
                                                                                Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                                HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                                Header="{Binding Data.TypeColumnFilter, Source={StaticResource SecProxy}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <ComboBox Style="{StaticResource DataGrid.InCellComboBox}"
                                                                              ItemsSource="{Binding Source={StaticResource PidDataTypes}}"
                                                                              SelectedItem="{Binding DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <!-- Value source - the single selector for where this row's value comes from. '(none)' = a
                                                             flat 0; 'Waveform' = the row's own waveform generator; any signal = the live engine model
                                                             (encoded with Scalar/Offset/Size). The headline control for a $2D row: point a custom
                                                             address at a live signal. A static-payload row ($1A / bin-extracted) still serves its bytes. -->
                                                        <DataGridTemplateColumn Width="150"
                                                                                Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                                HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                                Header="{Binding Data.SignalColumnFilter, Source={StaticResource SecProxy}}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <ComboBox Style="{StaticResource DataGrid.InCellComboBox}"
                                                                              ItemsSource="{Binding SignalSourceOptions}"
                                                                              DisplayMemberPath="Display"
                                                                              SelectedItem="{Binding SelectedSource, UpdateSourceTrigger=PropertyChanged}"
                                                                              ToolTip="Where this PID's value comes from. '(none)' = a flat 0; 'Waveform' = the row's waveform generator; any signal = the live engine model (encoded with this row's Scalar/Offset/Size)."/>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Binding="{Binding Scalar, StringFormat=G, UpdateSourceTrigger=LostFocus}" Width="78"
                                                                            Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                            HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                            Header="{Binding Data.ScalarColumnFilter, Source={StaticResource SecProxy}}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"
                                                                            EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"/>
                                                        <DataGridTextColumn Binding="{Binding Offset, StringFormat=G, UpdateSourceTrigger=LostFocus}" Width="78"
                                                                            Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                            HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                            Header="{Binding Data.OffsetColumnFilter, Source={StaticResource SecProxy}}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"
                                                                            EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"/>
                                                        <DataGridTextColumn Binding="{Binding Unit, UpdateSourceTrigger=LostFocus}"   Width="72"
                                                                            Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                            HeaderTemplate="{StaticResource PidColumnHeader}"
                                                                            Header="{Binding Data.UnitColumnFilter, Source={StaticResource SecProxy}}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"
                                                                            EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"/>
                                                        <DataGridTextColumn Header="Live"   Binding="{Binding LiveValue}" IsReadOnly="True" Width="90"
                                                                            Visibility="{Binding Data.IsNotMode1A, Source={StaticResource SecProxy}, Converter={StaticResource BoolToVis}}"
                                                                            ElementStyle="{StaticResource DataGrid.TextColumnElement}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DockPanel>
                                            </Expander>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right-side stack: Waveform inspector (top, sized to content)
                 and Advanced card (fills the remainder). Each card binds to
                 its own DataContext - waveform per-PID, advanced per-ECU - so
                 changing ECU or selected PID re-targets the appropriate card. -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <!-- Waveform inspector. Bound to the setup-selected ECU's
                 selected PID's waveform so changing ECU here flips the
                 waveform fields too. -->
            <Border Grid.Row="0" Style="{StaticResource Card}"
                    DataContext="{Binding SetupSelectedEcu.SelectedPid.Waveform}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Waveform"
                               Style="{StaticResource Text.Subtitle}"
                               Margin="0,0,0,12"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Generator for the selected PID."
                               Style="{StaticResource Hint14}"
                               Margin="0,-4,0,12"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="74"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="0" Grid.Column="0" Content="Shape"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                                      ItemsSource="{Binding Source={StaticResource WaveformShapes}}"
                                      SelectedItem="{Binding Shape, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="1" Grid.Column="0" Content="Amplitude"
                                   Visibility="{Binding SupportsAmplitude, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                                     Text="{Binding Amplitude, StringFormat=G, UpdateSourceTrigger=LostFocus}"
                                     Visibility="{Binding SupportsAmplitude, Converter={StaticResource BoolToVis}}"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="2" Grid.Column="0" Content="Offset"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                     Text="{Binding Offset, StringFormat=G, UpdateSourceTrigger=LostFocus}"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="3" Grid.Column="0" Content="Freq (Hz)"
                                   Visibility="{Binding SupportsFrequency, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,2"
                                     Text="{Binding FrequencyHz, StringFormat=G, UpdateSourceTrigger=LostFocus}"
                                     Visibility="{Binding SupportsFrequency, Converter={StaticResource BoolToVis}}"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="4" Grid.Column="0" Content="Phase (°)"
                                   Visibility="{Binding SupportsFrequency, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="0,2"
                                     Text="{Binding PhaseDeg, StringFormat=G, UpdateSourceTrigger=LostFocus}"
                                     Visibility="{Binding SupportsFrequency, Converter={StaticResource BoolToVis}}"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="5" Grid.Column="0" Content="Duty (0..1)"
                                   Visibility="{Binding SupportsDuty, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Margin="0,2"
                                     Text="{Binding DutyCycle, StringFormat=G, UpdateSourceTrigger=LostFocus}"
                                     Visibility="{Binding SupportsDuty, Converter={StaticResource BoolToVis}}"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <!-- CsvFile shape: picker + loop mode. The picker
                                 button validates the file before saving the
                                 path (column A strictly-increasing time,
                                 column B numeric, optional header tolerated).
                                 The display label collapses long paths to the
                                 file name so the inspector stays readable. -->
                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="6" Grid.Column="0" Content="CSV file"
                                   Visibility="{Binding SupportsCsv, Converter={StaticResource BoolToVis}}"/>
                            <Grid Grid.Row="6" Grid.Column="1" Margin="0,2"
                                  Visibility="{Binding SupportsCsv, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CsvFileDisplay}"
                                           ToolTip="{Binding CsvFilePath}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource Font.Mono}"/>
                                <Button Grid.Column="1" Margin="6,0,0,0" Padding="8,2"
                                        Content="Browse..."
                                        Command="{Binding PickCsvFileCommand}"/>
                                <Button Grid.Column="2" Margin="4,0,0,0" Padding="8,2"
                                        Content="Clear"
                                        Command="{Binding ClearCsvFileCommand}"/>
                            </Grid>

                            <Label Style="{StaticResource Label.FormPair}" Grid.Row="7" Grid.Column="0" Content="On end"
                                   Visibility="{Binding SupportsCsv, Converter={StaticResource BoolToVis}}"/>
                            <ComboBox Grid.Row="7" Grid.Column="1" Margin="0,2"
                                      ItemsSource="{Binding Source={StaticResource CsvLoopModes}}"
                                      SelectedItem="{Binding CsvLoopMode, UpdateSourceTrigger=PropertyChanged}"
                                      Visibility="{Binding SupportsCsv, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Advanced card. Per-ECU settings that don't fit the
                 selected-ECU inspector in the main window OR aren't tied to
                 a single PID. Exposes ISO 15765-2 FlowControl BlockSize, the
                 $27 SecurityAccess module picker, and the embedded PID-library
                 auto-respond gate; further per-ECU diagnostic-stack knobs will
                 follow. Margin top of 12 matches the gap the parent column
                 already imposes between sibling cards in the main editor pane. -->
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Margin="0,12,0,0"
                    DataContext="{Binding SetupSelectedEcu}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Advanced"
                               Style="{StaticResource Text.Subtitle}"
                               Margin="0,0,0,12"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Per-ECU diagnostic-stack settings."
                               Style="{StaticResource Hint14}"
                               Margin="0,-4,0,12"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="74"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ISO 15765-2 FlowControl BlockSize. The ECU
                                 returns FC = 30 BS 00 after a First Frame;
                                 BS counts how many Consecutive Frames the
                                 tester may send before waiting for another
                                 FC. 0 = unrestricted (send all CFs in one
                                 burst); 1 = strict (one CF per FC, needed
                                 by the 6Speed.T43 tester to recognise a
                                 T43 TCM). -->
                            <Label Style="{StaticResource Label.FormPair}"
                                   Grid.Row="0" Grid.Column="0" Content="FC.BS"/>
                            <TextBox x:Name="AdvancedFcBsTextBox"
                                     Grid.Row="0" Grid.Column="1" Margin="0,2"
                                     Text="{Binding FlowControlBlockSizeHex, UpdateSourceTrigger=LostFocus}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     ToolTip="ISO 15765-2 FlowControl BlockSize emitted on First Frame reception. 0x00 = unrestricted; 0x01 = one Consecutive Frame per FC cycle (needed by some testers, e.g. 6Speed.T43)."/>

                            <!-- Persona (diagnostic dispatch table) picker for
                                 THIS ECU. "GM Gen 4" = the GMW3110 stack;
                                 "Ford" = the Ford UDS (PCMTec) dispatcher.
                                 Binds EcuViewModel.SelectedPersonaOption, which
                                 swaps Model.Persona on this ECU only and resets
                                 its security state - it does NOT touch the other
                                 ECUs on the bus. Persisted per-ECU via
                                 ConfigSchema.PidDto.PersonaId. -->
                            <Label Style="{StaticResource Label.FormPair}"
                                   Grid.Row="1" Grid.Column="0" Content="Persona"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                                      Height="{Binding ActualHeight, ElementName=AdvancedFcBsTextBox}"
                                      ItemsSource="{Binding AvailablePersonas}"
                                      SelectedItem="{Binding SelectedPersonaOption}"
                                      DisplayMemberPath="Label"
                                      ToolTip="Diagnostic dispatch table this ECU presents on the wire. GM Gen 4 = the GMW3110 stack; Ford = the Ford UDS (PCMTec) dispatcher. Applies to this ECU only and resets its security state."/>

                            <!-- $27 SecurityAccess module picker. Identical
                                 wiring to the MainWindow Selected-ECU pane's
                                 "Sec module" field so a change here is
                                 reflected there (and vice versa) - both bind
                                 SelectedSecurityModuleId on the same shared
                                 EcuViewModel, and EcuViewModel.ApplyModuleSelection
                                 swaps the live module + resets security state.
                                 "(none)" makes $27 return NRC $11. -->
                            <Label Style="{StaticResource Label.FormPair}"
                                   Grid.Row="2" Grid.Column="0" Content="Sec module"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                                      Height="{Binding ActualHeight, ElementName=AdvancedFcBsTextBox}"
                                      ItemsSource="{Binding AvailableSecurityModuleIds}"
                                      SelectedItem="{Binding SelectedSecurityModuleId}"
                                      FontFamily="{StaticResource Font.Mono}"
                                      ToolTip="Seed/key algorithm for this ECU. (none) makes $27 return NRC $11. Picking an entry rebuilds the security module and clears any prior unlock / lockout state."/>

                            <!-- Divider splitting the diagnostic-stack knobs above from the Bin sub-section
                                 below. Spans both columns; extra top margin opens a gap from the Sec module row. -->
                            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                    Style="{StaticResource SectionDivider}" Margin="0,16,0,10"/>

                            <!-- Bin sub-section header with its Load / Clear actions parked top-right, mirroring
                                 the ECU picker toolbar's right-of-title placement. The buttons reuse that toolbar's
                                 28x22 glyph pattern (Segoe MDL2 Assets) so the two rows share a control vocabulary.
                                 The bin is both this ECU's identity source (the picker inspects the readback and
                                 prompts before overwriting placeholder VIN / part numbers) and its flash source
                                 (Service $23 reads, ford-uds persona). -->
                            <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Bin"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                           FontWeight="SemiBold" FontSize="15"/>
                                <Button Grid.Column="1" Width="28" Height="22" Padding="0" Margin="0,0,6,0"
                                        Command="{Binding LoadInfoFromBinCommand}"
                                        ToolTip="Pick a GM ECU flash readback (.bin). Sets it as this ECU's identity source (prompts before overwriting $1A DIDs) and flash bin source (Service $23 reads).">
                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Grid.Column="2" Width="28" Height="22" Padding="0"
                                        Command="{Binding ClearBinCommand}"
                                        ToolTip="Forget the selected bin: clears the flash source and the name shown. Already-loaded identity DIDs are kept.">
                                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <!-- Loaded-bin filename, full width across both columns. Read-only; the full path
                                 sits in the tooltip since the display value is the filename only. -->
                            <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,2"
                                     IsReadOnly="True"
                                     Text="{Binding BinFileDisplay, Mode=OneWay}"
                                     ToolTip="{Binding FlashBinPath}"
                                     VerticalContentAlignment="Center"
                                     TextAlignment="Left"
                                     FontFamily="{StaticResource Font.Mono}"/>

                            <!-- Flash-timing knobs. A simulator answers instantly (a flash finishes in
                                 <10 s); a real PCM takes 30 s+. These let any persona model realistic
                                 timing. Both default 0 = instant. Honoured by every flash path
                                 (Ford UDS $B1/$36 and GM SPS $31/$36). -->
                            <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                    Style="{StaticResource SectionDivider}" Margin="0,16,0,10"/>

                            <Label Style="{StaticResource Label.FormPair}"
                                   Grid.Row="7" Grid.Column="0" Content="Xfer ms"/>
                            <TextBox x:Name="AdvancedFlashXferTextBox"
                                     Grid.Row="7" Grid.Column="1" Margin="0,2"
                                     Text="{Binding FlashTransferDelayMs, UpdateSourceTrigger=LostFocus}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     ToolTip="Per-block delay (ms) before each $36 TransferData reply, to model real flash-program time. 0 = instant. ~30 ms over ~960 blocks gives a ~30 s write. Keep under ~2 s or the tester read-times-out."/>

                            <Label Style="{StaticResource Label.FormPair}"
                                   Grid.Row="8" Grid.Column="0" Content="Erase ms"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Margin="0,2"
                                     Text="{Binding FlashEraseDelayMs, UpdateSourceTrigger=LostFocus}"
                                     FontFamily="{StaticResource Font.Mono}"
                                     ToolTip="Modelled erase time (ms). The erase positive response is simply deferred by this much - the ECU goes quiet then answers when done (no ResponsePending; PCMTec rejects a pending reply to the $B1 erase). 0 = instant."/>

                            <!-- RAM-read fallback. When ticked, a $23 ReadMemoryByAddress that
                                 targets an address beyond the loaded bin (RAM) is answered with a
                                 positive zero-filled response instead of NRC $31 RequestOutOfRange.
                                 Applies to every persona; in-bin reads still serve the real bytes. -->
                            <Border Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                                    Style="{StaticResource SectionDivider}" Margin="0,16,0,10"/>

                            <CheckBox Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2"
                                      Content="Answer RAM reads with zeros"
                                      IsChecked="{Binding RamReadReturnsZeros}"
                                      ToolTip="When ticked, a $23 ReadMemoryByAddress for an address past the loaded bin's length (RAM) returns a positive response padded with 0x00 bytes instead of NRC $31 RequestOutOfRange. Applies to every persona; addresses inside the bin still read the real bytes."/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
