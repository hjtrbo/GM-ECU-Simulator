<UserControl x:Class="GmEcuSimulator.Views.BinReplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:replay="clr-namespace:Common.Replay;assembly=EcuSim.Common">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="LoopModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="replay:BinReplayLoopMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
            <StackPanel>
                <!-- Row 1: load actions + state pill + elapsed -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Load…"
                            Style="{StaticResource Button.Primary}"
                            Command="{Binding LoadFileCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Open a .bin or .csv. CSVs are converted on-the-fly via CsvParser (HP Tuners / PCMTEC / GMLAN formats)."/>
                    <Button Grid.Column="1" Content="Load synthetic demo"
                            Command="{Binding LoadDemoCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Loads a deterministic 4-channel in-memory bin (RPM/TPS/Coolant/TransTemp). For wiring up the start/stop hooks before the real bin loader lands."/>
                    <Button Grid.Column="2" Content="Unload"
                            Command="{Binding UnloadCommand}"/>

                    <Border Grid.Column="4"
                            Background="{DynamicResource Bg.SurfaceBrush}"
                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="11"
                            Padding="10,3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6"
                                     Fill="{DynamicResource Accent.PrimaryBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StateLabel}"
                                       Style="{StaticResource Text.Caption}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="•" Margin="10,0" Style="{StaticResource Text.Caption}"
                                       Foreground="{DynamicResource Text.TertiaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ElapsedSummary}"
                                       Style="{StaticResource Text.Mono}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 2: file path and channel summary -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="File"
                               Style="{StaticResource Text.Caption}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding FilePathLabel}"
                               Style="{StaticResource Text.Mono}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="•"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{DynamicResource Text.TertiaryBrush}"
                               Margin="10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding ChannelSummary}"
                               Style="{StaticResource Text.Caption}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Row 3: loop mode + autoload -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Loop mode"
                               Style="{StaticResource Text.Caption}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource LoopModes}}"
                              SelectedItem="{Binding LoopMode}"
                              MinWidth="140"
                              ToolTip="HoldLast freezes at the last sample. Loop wraps to the start. Stop transitions to Stopped at end-of-bin."/>
                    <Rectangle Width="1" Margin="16,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                    <CheckBox Content="Auto-load on app start"
                              IsChecked="{Binding AutoLoadOnStart}"
                              VerticalAlignment="Center"
                              ToolTip="Persists the loaded bin path in ecu_config.json and re-loads on next launch."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Channels}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ECU"     Binding="{Binding EcuLabel}"   Width="220"/>
                <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="90"/>
                <DataGridTextColumn Header="Name"    Binding="{Binding Name}"       Width="*" MinWidth="160"/>
                <DataGridTextColumn Header="Unit"    Binding="{Binding Unit}"       Width="70"/>
                <DataGridTextColumn Header="Size"    Binding="{Binding SizeBytes}"  Width="60"/>
                <DataGridTextColumn Header="Live"    Binding="{Binding LiveValue}"  Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
