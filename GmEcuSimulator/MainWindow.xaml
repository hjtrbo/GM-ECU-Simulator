<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GmEcuSimulator.Converters"
        xmlns:views="clr-namespace:GmEcuSimulator.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:glitch="clr-namespace:Common.Glitch;assembly=EcuSim.Common"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="GmEcuSimulator.MainWindow"
        Title="{Binding WindowTitle, FallbackValue=GM ECU Simulator}"
        Icon="/Resources/app.ico"
        Height="900" Width="1360"
        MinHeight="710" MinWidth="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StatusToBrushConverter    x:Key="StatusToBrush"/>

        <!--
            Validation error template. Draws a 1px red border around the
            adorned input and surfaces the first error message as a tooltip.
            Applied to inspector textboxes via local Validation.ErrorTemplate.
            The error binding goes through AdornedElement so it picks up the
            validation message that INotifyDataErrorInfo raised.
        -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="placeholder">
                    <Border BorderBrush="#E04848" BorderThickness="1"/>
                </AdornedElementPlaceholder>
            </StackPanel>
        </ControlTemplate>

        <!--
            Implicit TextBox augmentation: when the binding raises a
            validation error, show the red border template above and copy
            the first error message into the TextBox's ToolTip so hovering
            the field explains what's wrong. BasedOn keeps the theme-supplied
            base style intact (font, padding, brushes) so the only change is
            the added validation behaviour.
        -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <ObjectDataProvider x:Key="GlitchActions" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="glitch:GlitchAction"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Window.Style>
        <StaticResource ResourceKey="Window.AppShell"/>
    </Window.Style>

    <DockPanel LastChildFill="True">

        <!--
            TITLEBAR.
            Custom chrome. The first 36 pixels are draggable via
            WindowChrome.CaptionHeight; interactive zones (menu, status pill,
            window buttons) opt out via IsHitTestVisibleInChrome=True.
        -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource Chrome.GradientBrush}" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Brand / title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <Border Width="18" Height="18" CornerRadius="3"
                        Background="{DynamicResource Accent.PrimaryBrush}"
                        Margin="0,0,8,0">
                    <TextBlock Text="G" Foreground="White"
                               FontFamily="{StaticResource Font.SansDisplay}"
                               FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding WindowTitle, FallbackValue=GM ECU Simulator}"
                           Style="{StaticResource Text.Body}"
                           Foreground="{DynamicResource Text.PrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Centre: J2534 status pill (live, accent-coloured dot + text) -->
            <Border Grid.Column="2" CornerRadius="11"
                    Background="{DynamicResource Bg.SurfaceBrush}"
                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                    BorderThickness="1"
                    Padding="10,3" Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="J2534 device registration state (HKLM\SOFTWARE\PassThruSupport.04.04\GmEcuSim)">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{Binding J2534Status, Converter={StaticResource StatusToBrush}}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding J2534Status}"
                               Style="{StaticResource Text.Caption}"
                               Foreground="{DynamicResource Text.PrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Right: window controls -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button x:Name="MinimizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMinimizeClicked"
                        ToolTip="Minimize">
                    <Path Data="{StaticResource Icon.Minimize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="MaximizeBtn"
                        Style="{StaticResource Button.Chrome}"
                        Click="OnMaximizeClicked"
                        ToolTip="Maximize">
                    <Path x:Name="MaxIcon"
                          Data="{StaticResource Icon.Maximize}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
                <Button x:Name="CloseBtn"
                        Style="{StaticResource Button.ChromeClose}"
                        Click="OnCloseWindowClicked"
                        ToolTip="Close">
                    <Path Data="{StaticResource Icon.Close}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          StrokeThickness="1.2"
                          Width="10" Height="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MENU BAR -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Bg.BaseBrush}"
                BorderBrush="{DynamicResource Border.SubtleBrush}"
                BorderThickness="0,0,0,1"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Menu Padding="6,2" Background="Transparent">
                <MenuItem Header="_File">
                    <MenuItem Header="_New"      Command="{Binding NewCommand}"    InputGestureText="Ctrl+N"/>
                    <MenuItem Header="_Open…"    Command="{Binding OpenCommand}"   InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="_Save"     Command="{Binding SaveCommand}"   InputGestureText="Ctrl+S"/>
                    <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                    <Separator/>
                    <MenuItem Header="_Import…"  Command="{Binding ImportCommand}"/>
                    <MenuItem Header="_Export…"  Command="{Binding ExportCommand}"/>
                    <Separator/>
                    <MenuItem Header="E_xit"     Click="OnExitClicked"/>
                </MenuItem>
                <MenuItem Header="_J2534">
                    <MenuItem Header="_Register as J2534 device…"
                              Command="{Binding RegisterJ2534Command}"
                              ToolTip="Writes HKLM\SOFTWARE\PassThruSupport.04.04\GmEcuSim. Triggers a UAC prompt."/>
                    <MenuItem Header="_Unregister"
                              Command="{Binding UnregisterJ2534Command}"
                              ToolTip="Removes only the GmEcuSim entry; never touches other vendors. Triggers a UAC prompt."/>
                    <Separator/>
                    <MenuItem Header="_Show registered devices…"
                              Command="{Binding ShowRegisteredDevicesCommand}"
                              ToolTip="Lists every J2534 device on this machine in both registry views. Read-only - no UAC."/>
                </MenuItem>
                <MenuItem Header="_ECU">
                    <MenuItem Header="_Add"     Command="{Binding AddEcuCommand}"/>
                    <MenuItem Header="_Remove"  Command="{Binding RemoveEcuCommand}"/>
                    <Separator/>
                    <MenuItem Header="Load info from BIN..."
                              Command="{Binding LoadEcuFromBinCommand}"
                              ToolTip="Pick a .bin (full-flash dump) and populate the selected ECU's GMW3110 identity DIDs ($90 VIN, $92/$98 HW, $C1/$C2 P/N, $CC diag addr) from offsets located in the bin. Currently a scaffold - the extractor is not wired up yet."/>
                    <Separator/>
                    <MenuItem Header="Drive HW _$3E keepalives"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding AllowPeriodicTesterPresent, Mode=TwoWay}"
                              ToolTip="When on, the simulator drives $3E TesterPresent on the host's behalf for any frame registered via PassThruStartPeriodicMsg. Off accepts the registration but skips the tick - delegating hosts have to keep their own P3C session alive."/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="_Setup window…"
                              Command="{Binding OpenSetupWindowCommand}"
                              InputGestureText="Ctrl+Shift+P"
                              ToolTip="Open the modeless setup window with PID parameters + waveform editor. The ECU selection there is independent of the main window's Selected ECU inspector."/>
                    <Separator/>
                    <MenuItem Header="_Theme" x:Name="ThemeMenu"
                              ToolTip="Switch the colour palette. Drop your own .xaml palette into %APPDATA%\GmEcuSimulator\Palettes\ to see it listed here."/>
                </MenuItem>
                <MenuItem Header="_Log">
                    <!-- Master gate. When unchecked, the four items below grey
                         out (their IsEnabled is bound to IsFileLoggingEnabled).
                         StaysOpenOnClick=True on every IsCheckable item keeps
                         the menu open so the user can flip several toggles at
                         once without re-opening the menu each time. -->
                    <MenuItem x:Name="LogToFileCheck"
                              Header="_Log to file"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding IsFileLoggingEnabled, Mode=TwoWay}"
                              ToolTip="Stream every bus + diagnostic line to %LOCALAPPDATA%\GmEcuSimulator\logs\bus_*.csv on a dedicated background thread. Independent of the 'Log traffic' textbox gate - use when high-volume downloads make the textbox impractical."/>
                    <MenuItem Header="_Open folder…"
                              Click="OnOpenLogFolderClicked"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Open the log directory in Explorer."/>
                    <Separator/>
                    <MenuItem Header="Include _J2534 calls"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogIncludeJ2534Calls, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="When on, pipe-level J2534 calls (Open/Connect/StartMsgFilter/etc.) reach the file. The textbox / Download tab mirror is unaffected."/>
                    <MenuItem Header="Include _bus traffic"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogIncludeBusTraffic, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="When on, every CAN frame (Rx/Tx, including HOST FILTERED) reaches the file. The textbox is unaffected."/>
                    <MenuItem Header="_Append description tag"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogAppendDescriptionTag, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Suffix every bus-frame line with a short human-readable tag (e.g. 'SecurityAccess - RequestSeed', 'ISO-TP FF (3110B) - TransferData @ 003FAFE0'). Tag is produced by Gmw3110Annotator from the raw bytes."/>
                    <MenuItem Header="_Collapse bulk transfers"
                              IsCheckable="True"
                              StaysOpenOnClick="True"
                              IsChecked="{Binding LogCollapseBulkTransfers, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoggingEnabled}"
                              ToolTip="Condense long ISO-TP transfers in the bus log: first 3 + last 3 CFs visible, middle replaced with a single '-- bulk transfer collapsed: N frames hidden --' marker. FC/TesterPresent noise inside the collapsed window is suppressed too. Threshold is 10 CFs - shorter transfers log normally."/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- STATUS BAR (bottom) -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Caption}"
                           Foreground="{DynamicResource Text.PrimaryBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pipe" Style="{StaticResource Text.Caption}" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="\\.\pipe\GmEcuSim.PassThru" Style="{StaticResource Text.MonoDim}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!--
            MAIN WORKSPACE.
            Two rows split by a horizontal GridSplitter. The "Maximize"
            checkbox in the bus-log tab collapses the editor row AND
            the outer margin / splitter so the tabbed workspace fills
            edge-to-edge.
        -->
        <Grid x:Name="MainContentGrid" Margin="14">
            <Grid.RowDefinitions>
                <!-- EditorRow MinHeight is the editor area's floor when the
                     user drags the horizontal splitter up. Maximize toggles
                     it to 0 from code-behind so the row can fully collapse. -->
                <RowDefinition x:Name="EditorRow" Height="*" MinHeight="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogRow"    Height="320" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- TWO PANE EDITOR (Row 0).
                 PIDs + Waveform moved to the modeless SetupWindow (see View
                 menu). This row keeps the ECU list + Selected ECU inspector. -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" MinWidth="0"/>
                    <ColumnDefinition Width="*"   MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- ECU sidebar.
                     Grid layout with Header (Auto) + ListBox (Star) so the
                     ListBox absorbs all remaining vertical space and its
                     inner ScrollViewer kicks in when ECU count exceeds the
                     visible area. The Selected-ECU inspector lives below
                     the PID grid now (middle column), not here. -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ECUs" Style="{StaticResource Text.SectionHeader}"
                                       Margin="0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Scrollable ECU list -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Ecus}"
                                 SelectedItem="{Binding SelectedEcu}"
                                 DisplayMemberPath="Name"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0" av:ItemsSource="{av:SampleData ItemCount=5}"/>
                    </Grid>
                </Border>

                <!-- Selected-ECU inspector card. Sole occupant of column 1
                     now that PIDs + Waveform live in the modeless setup
                     window. WrapPanel inside the ScrollViewer lets each
                     field cell (fixed 280px) flow into multiple columns
                     when the column is wide and collapse to one when it
                     shrinks. Load-from-bin button sits below the WrapPanel
                     as a full-width footer so it never gets stranded next
                     to a half-empty row. -->
                <Border Grid.Column="1" Style="{StaticResource Card}"
                        DataContext="{Binding SelectedEcu}"
                        Visibility="{Binding ConverterParameter=NotNull, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Selected ECU"
                                           Style="{StaticResource Text.Subtitle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Style="{StaticResource Text.Caption}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </Grid>

                            <Button DockPanel.Dock="Bottom" Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Content="Load Info From Bin..."
                                    Command="{Binding LoadInfoFromBinCommand}"
                                    ToolTip="Pick a T43/E38/E67 flash image and populate the DID fields by tracing the $1A handler. Walks the dispatcher to find each supported DID's source flash address - no per-family hardcoding."/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <WrapPanel Orientation="Horizontal">
                                    <WrapPanel.Resources>
                                        <!-- Each form cell is a fixed-width Grid so the WrapPanel
                                             can lay out 2 columns when room permits, 1 when narrow.
                                             280px cell + 12px right gap = ~292px stride; two cells
                                             fit once the middle column exceeds ~600px. -->
                                        <Style x:Key="FormCell" TargetType="Grid">
                                            <Setter Property="Width" Value="280"/>
                                            <Setter Property="Margin" Value="0,0,12,4"/>
                                        </Style>
                                    </WrapPanel.Resources>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Name"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Req CAN"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding PhysicalRequestCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="USDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UsdtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="UUDT resp"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding UudtResponseCanIdHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="FC.BS"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding FlowControlBlockSizeHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="ISO 15765-2 FlowControl BlockSize byte (FC.BS). 0 = send all CFs without further FC. Set to 1 to match real T43 (FC = 30 01 00)."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="FC.STmin"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding FlowControlSeparationTimeHex, UpdateSourceTrigger=LostFocus}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="ISO 15765-2 FlowControl SeparationTime byte (FC.STmin). 0 = no inter-frame delay. Values 1..7F = N ms, F1..F9 = 100..900 us."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$36 addr"/>
                                        <ComboBox Grid.Column="1" Margin="0,2"
                                                  ItemsSource="{Binding DownloadAddressByteCountOptions}"
                                                  SelectedItem="{Binding DownloadAddressByteCount}"
                                                  FontFamily="{StaticResource Font.Mono}"
                                                  ToolTip="Number of bytes in the $36 TransferData startingAddress field. GMW3110 permits 2..4. T43-era ECUs use 4; 3 only fits up to 16 MiB and corrupts the captured image if the host sends a 4-byte address."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$90 VIN"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding Vin, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="17"
                                                 ToolTip="GMW3110 §8.3.2 DID $90 - Vehicle Identification Number (17 ASCII bytes). Blank removes the DID so $1A returns NRC $31."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$92 HW#"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding SupplierHardwareNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 ToolTip="GMW3110 §8.3.2 DID $92 - System Supplier ECU Hardware Number (ASCII). Blank removes the DID so $1A returns NRC $31."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$98 HW Ver"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding SupplierHardwareVersion, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 ToolTip="GMW3110 §8.3.2 DID $98 - System Supplier ECU Hardware Version Number (ASCII)."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$C1 End P/N"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding EndModelPartNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="10"
                                                 ToolTip="GMW3110 §8.3.2 DID $C1 - End Model Part Number. Wire format is 4 raw bytes BE (e.g. 0x017240DB = decimal 24264923). Blank clears it."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$C2 Base P/N"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding BaseModelPartNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 ToolTip="GMW3110 §8.3.2 DID $C2 - Base Model Part Number Identification (ASCII)."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="$CC Diag Addr"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding EcuDiagnosticAddress4ByteHex, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="10"
                                                 ToolTip="GMW3110 §8.3.2 DID $CC - ECU Diagnostic Address. Wire format is 4 raw bytes BE (e.g. 0x00000018). Blank clears it."/>
                                    </Grid>

                                    <!-- EEPROM-block informational fields (Stage 2 SegmentReader).
                                         These aren't $1A wire DIDs; they're the calibration-PN /
                                         BCC / programming-date / supplier-trace stamps that GM
                                         tools surface alongside the diagnostic identity. Populated
                                         by "Load Info From Bin..."; manually editable; not
                                         currently persisted across simulator restarts. -->
                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Cal P/N"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding CalibrationPartNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="Calibration broadcast PN from the EEPROM block (PCM field). Different from $C1 - this is the cal-ID tuners refer to as 'the OS'."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="BCC"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding BroadcastCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="4"
                                                 ToolTip="Broadcast Code - 4-char alphanumeric. Last 4 digits of the calibration PN by GM convention."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Prog Date"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding ProgrammingDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 MaxLength="8"
                                                 ToolTip="Programming date stamp from the EEPROM block, decoded YYYYMMDD (e.g. 20220326). Stored as 4 BCD bytes in flash."/>
                                    </Grid>

                                    <Grid Style="{StaticResource FormCell}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Style="{StaticResource Label.FormPair}" Grid.Column="0" Content="Trace"/>
                                        <TextBox Grid.Column="1" Margin="0,2"
                                                 Text="{Binding TraceCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                 FontFamily="{StaticResource Font.Mono}"
                                                 ToolTip="Bosch/Delphi supplier trace stamp (e.g. DV5053Q103619515) - 16 chars. Identifies the physical ECU hardware variant."/>
                                    </Grid>
                                </WrapPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
            </Grid>

            <!-- Horizontal splitter (Row 1) -->
            <GridSplitter x:Name="EditorSplitter" Grid.Row="1" Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Margin="0,6"
                          Background="Transparent">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Border Background="Transparent">
                            <Rectangle Height="1" Fill="{DynamicResource Border.SubtleBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- TABBED WORKSPACE (Row 2) -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Bg.SurfaceBrush}"
                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <TabControl x:Name="BusLogTabControl" Margin="0">
                    <!-- Bus log tab -->
                    <TabItem Header="Bus log">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="LogTrafficCheck"
                                              Content="Log traffic"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsLoggingEnabled, Mode=TwoWay}"
                                              ToolTip="Master gate for the bus log AND the Download tab's mirror. Off by default - at $AA Fast 25Hz the bus frames alone can flood the textbox quickly."/>
                                    <Button Content="Clear" Click="OnClearLogClicked"
                                            Margin="16,0,0,0"/>
                                    <Rectangle Width="1" Margin="12,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <!-- File-log status only. The Log-to-file toggle and Open-folder
                                         button moved to the Log menu (top-level) so all file-log
                                         controls live in one place. The live status counter stays
                                         here so the user can see byte/line totals at a glance. -->
                                    <TextBlock Text="{Binding FileLogStatus, FallbackValue=Not logging}"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource Font.Mono}"
                                               Foreground="{DynamicResource Text.SecondaryBrush}"
                                               ToolTip="File-log status. Toggle 'Log to file' under the Log menu to start/stop the sink."/>
                                    <Rectangle Width="1" Margin="12,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox x:Name="MaximizeBusLogCheck"
                                              Content="Maximize"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsMaximized, Mode=TwoWay}"
                                              ToolTip="Collapse the ECU/PID editor and fill the window with the workspace tabs. Shared with the Download tab's Maximize toggle."/>
                                    <CheckBox x:Name="HideTesterPresentCheck"
                                              Content="Hide $3E"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding SuppressTesterPresentInWindow, Mode=TwoWay}"
                                              ToolTip="Hide TesterPresent keepalives ($3E requests and $7E positive responses) from this log window only. The file-log capture is not affected."/>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="LogBoxColumn"     Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition x:Name="IpcLogBoxColumn"  Width="*"/>
                                </Grid.ColumnDefinitions>

                                <DockPanel Grid.Column="0">
                                    <Border DockPanel.Dock="Top"
                                            Background="{DynamicResource Bg.ElevatedBrush}"
                                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource Accent.PrimaryBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="CAN frames"
                                                       Style="{StaticResource Text.Caption}"
                                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="Tx / Rx"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="LogBox"
                                             Style="{StaticResource TextBox.Log}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"/>
                                </DockPanel>

                                <GridSplitter x:Name="BusLogSplitter"
                                              Grid.Column="1" Width="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              MouseDoubleClick="OnBusLogSplitterDoubleClick"
                                              ToolTip="Drag to resize the CAN frames / J2534 calls panes. Double-click to reset to a 50/50 split.">
                                    <GridSplitter.Template>
                                        <ControlTemplate TargetType="{x:Type GridSplitter}">
                                            <Border Background="Transparent">
                                                <Rectangle Width="1" Fill="{DynamicResource Border.SubtleBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </GridSplitter.Template>
                                </GridSplitter>

                                <DockPanel Grid.Column="2">
                                    <Border DockPanel.Dock="Top"
                                            Background="{DynamicResource Bg.ElevatedBrush}"
                                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource Status.SuccessBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="J2534 calls"
                                                       Style="{StaticResource Text.Caption}"
                                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="control plane"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="IpcLogBox"
                                             Style="{StaticResource TextBox.Log}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"/>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>

                    <!-- Download workspace tab.
                         Live monitor of the GMW3110 programming-flow state for
                         the ECU currently selected in the sidebar. Each step
                         is a traffic light (red = precondition not met, amber
                         = next required step, green = satisfied). The TX / RX
                         log mirrors the bus-log content; the master toggle is
                         shared with the Bus log tab via IsLoggingEnabled. -->
                    <TabItem Header="Download">
                        <DockPanel DataContext="{Binding DownloadWorkspace}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ECU"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding EcuName}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="Reset ECU state"
                                            Margin="14,0,0,0"
                                            Style="{StaticResource Button.Ghost}"
                                            Command="{Binding ResetEcuStateCommand}"
                                            ToolTip="Equivalent to $20 ReturnToNormalMode: clears the programming session, security unlock, and download buffer. Fires the unsolicited $60 if a host channel is still active."/>
                                    <Rectangle Width="1" Margin="16,3" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox Content="Log traffic"
                                              IsChecked="{Binding DataContext.IsLoggingEnabled, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              ToolTip="Shared toggle with the Bus log tab. Mirrors all CAN frames + J2534 calls into the panel below."/>
                                    <Button Content="Clear" Click="OnDownloadClearLogClicked"
                                            Margin="16,0,0,0"/>
                                    <Rectangle Width="1" Margin="12,4" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox Content="Maximize"
                                              IsChecked="{Binding DataContext.IsMaximized, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              ToolTip="Collapse the ECU/PID editor and fill the window with the workspace tabs. Shared with the Bus log tab's Maximize toggle."/>
                                </StackPanel>
                            </Border>

                            <!-- Bottom status line: human-readable description of the
                                 current required step or the completion state. -->
                            <Border DockPanel.Dock="Bottom"
                                    Background="{DynamicResource Bg.BaseBrush}"
                                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,6">
                                <TextBlock Text="{Binding StatusLine}"
                                           Style="{StaticResource Text.Caption}"
                                           Foreground="{DynamicResource Text.PrimaryBrush}"/>
                            </Border>

                            <!-- Two-column split: traffic-light tree (left) + tx/rx log (right). -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280" MinWidth="280"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Traffic-light tree.
                                     Each row: coloured Ellipse + label + optional sub-text.
                                     A 1px Rectangle between rows acts as the connector. -->
                                <Border Grid.Column="0" Padding="18,14"
                                        BorderBrush="{DynamicResource Border.SubtleBrush}"
                                        BorderThickness="0,0,1,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock Text="ENTRY SEQUENCE"
                                                       Style="{StaticResource Text.SectionHeader}"
                                                       Margin="0,0,0,10"/>

                                            <!-- $28 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Brush28}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$28 DisableNormalCommunication"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Width="1" Height="10" Margin="6,0"
                                                       HorizontalAlignment="Left"
                                                       Fill="{DynamicResource Border.SubtleBrush}"/>

                                            <!-- $A5/01 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding BrushA5Req}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$A5 / $01 RequestProgrammingMode"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Width="1" Height="10" Margin="6,0"
                                                       HorizontalAlignment="Left"
                                                       Fill="{DynamicResource Border.SubtleBrush}"/>

                                            <!-- $A5/03 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding BrushA5Enable}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$A5 / $03 EnableProgrammingMode"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Width="1" Height="10" Margin="6,0"
                                                       HorizontalAlignment="Left"
                                                       Fill="{DynamicResource Border.SubtleBrush}"/>

                                            <!-- $27 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Brush27}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$27 SecurityAccess (unlock)"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Width="1" Height="10" Margin="6,0"
                                                       HorizontalAlignment="Left"
                                                       Fill="{DynamicResource Border.SubtleBrush}"/>

                                            <!-- $34 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Brush34}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$34 RequestDownload"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Width="1" Height="10" Margin="6,0"
                                                       HorizontalAlignment="Left"
                                                       Fill="{DynamicResource Border.SubtleBrush}"/>

                                            <!-- $36 (with progress) -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Brush36}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$36 TransferData"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding S36Progress}"
                                                           Style="{StaticResource Text.MonoDim}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>

                                            <TextBlock Text="EXIT"
                                                       Style="{StaticResource Text.SectionHeader}"
                                                       Margin="0,18,0,10"/>

                                            <!-- $20 -->
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,12,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Brush20}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="$20 ReturnToNormalMode"
                                                           Style="{StaticResource Text.Body}"
                                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="(or P3C TesterPresent timeout - 5 s)"
                                                       Style="{StaticResource Text.Hint}"
                                                       Margin="26,2,0,0"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- TX / RX log mirror -->
                                <DockPanel Grid.Column="1">
                                    <Border DockPanel.Dock="Top"
                                            Background="{DynamicResource Bg.ElevatedBrush}"
                                            BorderBrush="{DynamicResource Border.SubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource Accent.PrimaryBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="TX / RX log"
                                                       Style="{StaticResource Text.Caption}"
                                                       Foreground="{DynamicResource Text.PrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="mirrors CAN frames + J2534 calls (gated by Log traffic)"
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="DownloadLogBox"
                                             Style="{StaticResource TextBox.Log}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"/>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>

                    <!-- Bin Replay tab -->
                    <TabItem Header="Bin Replay">
                        <views:BinReplayView DataContext="{Binding BinReplay}"/>
                    </TabItem>

                    <!-- Security ($27) tab -->
                    <TabItem Header="Security">
                        <DockPanel DataContext="{Binding SelectedEcu}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ECU"
                                                   Style="{StaticResource Text.Caption}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name, FallbackValue=(none selected)}"
                                                   Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Rectangle Width="1" Margin="16,3" Fill="{DynamicResource Border.SubtleBrush}"/>
                                        <TextBlock Text="Module"
                                                   Style="{StaticResource Text.Caption}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <ComboBox ItemsSource="{Binding AvailableSecurityModuleIds}"
                                                  SelectedItem="{Binding SelectedSecurityModuleId}"
                                                  Width="340" VerticalAlignment="Center"
                                                  ToolTip="Seed/key algorithm for this ECU. (none) makes $27 return NRC $11."/>
                                        <Button Content="Reset state"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource Button.Ghost}"
                                                Command="{Binding DataContext.ResetSecurityCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Re-lock this ECU and clear the attempt counter, pending seed, and lockout deadline. Equivalent to a power-cycle for $27 only."/>
                                        <CheckBox Content="Bypass security"
                                                  Margin="16,0,0,0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding BypassSecurity}"
                                                  ToolTip="Short-circuit $27. The ECU emits seed=00 00 on requestSeed and transitions to unlocked on sendKey regardless of the key value. Models stub-security levels seen on real hardware (e.g. T43 TCM at level 1, per HP Tuners' &quot;no unlock service required&quot;)."/>
                                    </StackPanel>
                                    <TextBlock Text="Module-specific config below. Values are passed to the module as JSON strings."
                                               Style="{StaticResource Text.Hint}"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource Bg.BaseBrush}"
                                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="STATUS" Style="{StaticResource Text.SectionHeader}" Margin="0"/>
                                        <TextBlock Text="{Binding SecurityStatusText, FallbackValue=-}"
                                                   Style="{StaticResource Text.Mono}"
                                                   Foreground="{DynamicResource Text.PrimaryBrush}"
                                                   ToolTip="Live ECU lock state. Counts down during a 10s lockout window after 3 failed key attempts."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="FAILED ATTEMPTS" Style="{StaticResource Text.SectionHeader}" Margin="0"/>
                                        <TextBlock Text="{Binding SecurityFailedAttemptsText, FallbackValue=-}"
                                                   Style="{StaticResource Text.Mono}"
                                                   Foreground="{DynamicResource Text.PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PENDING SEED" Style="{StaticResource Text.SectionHeader}" Margin="0"/>
                                        <TextBlock Text="{Binding SecurityPendingSeedText, FallbackValue=-}"
                                                   Style="{StaticResource Text.Mono}"
                                                   Foreground="{DynamicResource Text.PrimaryBrush}"
                                                   ToolTip="Level and bytes of the last requestSeed response - cleared on successful unlock or lockout arm."/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding SecurityModuleConfigEntries}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True"
                                      CanUserDeleteRows="True"
                                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key"
                                                        Binding="{Binding Key, UpdateSourceTrigger=LostFocus}"
                                                        Width="280"/>
                                    <DataGridTextColumn Header="Value"
                                                        Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <!-- Glitch settings tab -->
                    <TabItem Header="Glitch settings">
                        <DockPanel DataContext="{Binding SelectedEcu}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ECU"
                                               Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name, FallbackValue=(none selected)}"
                                               Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Rectangle Width="1" Margin="16,3" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <CheckBox Content="Enable glitch injection"
                                              IsChecked="{Binding Glitch.Enabled}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="prep - not yet wired into bus logic"
                                               Style="{StaticResource Text.Hint}"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <DataGrid Grid.Column="0"
                                          ItemsSource="{Binding Glitch.Services}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          BorderThickness="0,0,1,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Service"
                                                            Binding="{Binding ServiceLabel}"
                                                            IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="Probability %"
                                                            Binding="{Binding ProbabilityPercent, UpdateSourceTrigger=LostFocus}"
                                                            Width="120"/>
                                        <DataGridTemplateColumn Header="Action" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Style="{StaticResource ComboBox.Cell}"
                                                              ItemsSource="{Binding Source={StaticResource GlitchActions}}"
                                                              SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Column="1" Padding="14,12">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="NRC pool"
                                                   Style="{StaticResource Text.Subtitle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="When EmitNrc fires, an NRC is randomly chosen from the ticked entries."
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel>
                                            <CheckBox Content="$11 serviceNotSupported"     IsChecked="{Binding Glitch.IncludeNrc11}" Margin="0,4"/>
                                            <CheckBox Content="$12 subFunctionNotSupported" IsChecked="{Binding Glitch.IncludeNrc12}" Margin="0,4"/>
                                            <CheckBox Content="$22 conditionsNotCorrect"    IsChecked="{Binding Glitch.IncludeNrc22}" Margin="0,4"/>
                                            <CheckBox Content="$31 requestOutOfRange"       IsChecked="{Binding Glitch.IncludeNrc31}" Margin="0,4"/>
                                            <CheckBox Content="$33 securityAccessDenied"    IsChecked="{Binding Glitch.IncludeNrc33}" Margin="0,4"/>
                                            <CheckBox Content="$78 busyResponsePending"     IsChecked="{Binding Glitch.IncludeNrc78}" Margin="0,4"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </TabItem>

                    <!-- Capture Bootloader tab.
                         Single checkbox flips bus.Capture.BootloaderCaptureEnabled
                         which is the SOLE switch that makes Service36Handler relax
                         its GMW3110 §8.13.4 NRC $31 bounds check and tells
                         EcuExitLogic to dump the assembled $36 buffer to disk on
                         session end. Unticked = spec-correct behaviour. -->
                    <TabItem Header="Bootloader">
                        <DockPanel DataContext="{Binding CaptureBootloader}" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="Enable bootloader capture"
                                              IsChecked="{Binding Enabled}"
                                              VerticalAlignment="Center"
                                              FontWeight="SemiBold"
                                              ToolTip="OFF (default): Service36Handler follows GMW3110 §8.13.4 strictly - out-of-range $36 addresses return NRC $31. ON: bounds check is relaxed (first $36's address is treated as base; the buffer grows as needed) and the assembled payload is dumped to disk when the programming session ends."/>
                                    <Rectangle Width="1" Margin="16,3" Fill="{DynamicResource Border.SubtleBrush}"/>
                                    <Button Content="Open folder"
                                            Command="{Binding OpenFolderCommand}"
                                            Style="{StaticResource Button.Ghost}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Refresh"
                                            Command="{Binding RefreshCommand}"
                                            Style="{StaticResource Button.Ghost}"/>
                                </StackPanel>
                            </Border>

                            <Border DockPanel.Dock="Bottom"
                                    Background="{DynamicResource Bg.BaseBrush}"
                                    BorderBrush="{DynamicResource Border.SubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,6">
                                <TextBlock Text="{Binding StatusText}"
                                           Style="{StaticResource Text.Caption}"
                                           Foreground="{DynamicResource Text.PrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="18,12,18,6">
                                    <StackPanel>
                                        <TextBlock Text="CAPTURE DIRECTORY"
                                                   Style="{StaticResource Text.SectionHeader}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CaptureDirectory}"
                                                   Style="{StaticResource Text.MonoDim}"
                                                   TextWrapping="NoWrap"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Text="CAPTURED FILES"
                                                   Style="{StaticResource Text.SectionHeader}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Each row is one programming session (a $34/$36 sequence ending in $20 ReturnToNormalMode or a P3C timeout). Filename embeds ECU name, UTC timestamp, base $36 address, and byte count."
                                                   Style="{StaticResource Text.Hint}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Captures}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          Margin="14,0,14,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File"     Binding="{Binding FileName}" Width="*"/>
                                        <DataGridTextColumn Header="Size"     Binding="{Binding SizeText}" Width="100"/>
                                        <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat=g}" Width="180"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>