<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Master theme. Merged once from App.xaml. The merge order matters -
        Brushes (whose merged palette decides the colour set) and Typography
        feed every control style below.

        To change the startup palette, edit Brushes.xaml's merge. To switch at
        runtime, call ThemeManager.Apply (which mutates the live brush
        instances declared by the active palette file).
    -->

    <ResourceDictionary.MergedDictionaries>
        <!-- Foundations -->
        <ResourceDictionary Source="/Resources/Theme/Brushes.xaml"/>
        <ResourceDictionary Source="/Resources/Theme/Typography.xaml"/>
        <ResourceDictionary Source="/Resources/Theme/Icons.xaml"/>

        <!-- Controls. Containers first so window/groupbox/scrollbar exist
             before composite controls reference them. -->
        <ResourceDictionary Source="/Resources/Controls/ScrollBar.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Containers.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Window.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Buttons.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Inputs.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/CheckBox.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Menus.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/Tabs.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/ListBox.xaml"/>
        <ResourceDictionary Source="/Resources/Controls/DataGrid.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
