<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Theme/Brushes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!--
        Type ramp. UI text uses Segoe UI Variable Text where available with
        Segoe UI as fallback. Monospace surfaces use Cascadia Mono (Windows
        Terminal default) falling back to Consolas. Sizes follow a 12 / 13 /
        15 / 18 / 24 scale; weights are SemiBold for headers, Regular
        elsewhere. Letter-spacing is left at WPF default.
    -->

    <FontFamily x:Key="Font.Sans">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.SansDisplay">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>

    <sys:Double x:Key="Font.Size.Caption">11</sys:Double>
    <sys:Double x:Key="Font.Size.Body">12.5</sys:Double>
    <sys:Double x:Key="Font.Size.BodyLarge">13.5</sys:Double>
    <sys:Double x:Key="Font.Size.Subtitle">15</sys:Double>
    <sys:Double x:Key="Font.Size.Title">18</sys:Double>
    <sys:Double x:Key="Font.Size.Mono">12</sys:Double>

    <!-- Named text styles. Used directly via Style="{StaticResource Text.Body}". -->

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.PrimaryBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.SecondaryBrush}"/>
    </Style>

    <Style x:Key="Text.Subtitle" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontFamily" Value="{StaticResource Font.SansDisplay}"/>
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Subtitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.Title" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontFamily" Value="{StaticResource Font.SansDisplay}"/>
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Title}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Section header used above panes ("ECUs", "PIDs", "Waveform"). -->
    <Style x:Key="Text.SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Caption}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.SecondaryBrush}"/>
        <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>

    <Style x:Key="Text.Mono" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Mono}"/>
    </Style>

    <Style x:Key="Text.MonoDim" TargetType="TextBlock" BasedOn="{StaticResource Text.Mono}">
        <Setter Property="Foreground" Value="{DynamicResource Mono.DimBrush}"/>
    </Style>

    <Style x:Key="Text.Hint" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontSize"   Value="{StaticResource Font.Size.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.TertiaryBrush}"/>
        <Setter Property="FontStyle"  Value="Italic"/>
    </Style>

</ResourceDictionary>
