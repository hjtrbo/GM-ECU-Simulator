<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Reusable Geometry paths for icons. 16x16 viewport unless noted; consumed
        as the Data of a Path. Sourced from Fluent System Icons, normalised to
        match the design grid. Stroke icons use StrokeThickness=1.5 by
        convention; filled icons use Fill.
    -->

    <!-- Window chrome -->
    <Geometry x:Key="Icon.Minimize">M 0 5 L 10 5</Geometry>
    <Geometry x:Key="Icon.Maximize">M 0 0 L 10 0 L 10 10 L 0 10 Z</Geometry>
    <Geometry x:Key="Icon.Restore">M 0 2 L 8 2 L 8 10 L 0 10 Z M 2 0 L 10 0 L 10 8</Geometry>
    <Geometry x:Key="Icon.Close">M 0 0 L 10 10 M 10 0 L 0 10</Geometry>

    <!-- Common actions / status -->
    <Geometry x:Key="Icon.Plus">M 8 2 L 8 14 M 2 8 L 14 8</Geometry>
    <Geometry x:Key="Icon.Minus">M 2 8 L 14 8</Geometry>
    <Geometry x:Key="Icon.Trash">M 3 5 L 13 5 M 5 5 L 5 3 L 11 3 L 11 5 M 4 5 L 5 14 L 11 14 L 12 5</Geometry>
    <Geometry x:Key="Icon.Folder">M 1 4 L 6 4 L 7 5 L 14 5 L 14 13 L 1 13 Z</Geometry>
    <Geometry x:Key="Icon.Save">M 2 2 L 11 2 L 13 4 L 13 13 L 2 13 Z M 4 2 L 4 6 L 10 6 L 10 2 M 5 9 L 11 9 M 5 11 L 11 11</Geometry>
    <Geometry x:Key="Icon.Reset">M 13 8 A 5 5 0 1 1 8 3 L 11 3 M 11 1 L 11 5</Geometry>
    <Geometry x:Key="Icon.Check">M 3 8 L 7 12 L 13 4</Geometry>
    <Geometry x:Key="Icon.Search">M 7 12 A 5 5 0 1 1 12 7 A 5 5 0 1 1 7 12 M 11 11 L 14 14</Geometry>

    <!-- Status -->
    <Geometry x:Key="Icon.Dot">M 4 8 A 4 4 0 1 0 12 8 A 4 4 0 1 0 4 8</Geometry>
    <Geometry x:Key="Icon.Warning">M 8 2 L 14 13 L 2 13 Z M 8 6 L 8 9 M 8 11 L 8 11.5</Geometry>

</ResourceDictionary>
