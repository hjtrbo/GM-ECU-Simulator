<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DRACULA  -  dark theme with violet / pink accents.
        The classic Dracula palette: charcoal-violet surfaces, cream text,
        and a saturated pop accent. Status colours stay vivid (lime,
        butter-yellow, scarlet) so warnings still feel like warnings.
    -->

    <Color x:Key="Bg.Base">#282A36</Color>
    <Color x:Key="Bg.Surface">#2D2F3F</Color>
    <Color x:Key="Bg.Elevated">#383A4A</Color>
    <Color x:Key="Bg.Hover">#44475A</Color>
    <Color x:Key="Bg.Active">#4E5168</Color>
    <Color x:Key="Bg.Selected">#44475A</Color>
    <Color x:Key="Bg.Disabled">#282A36</Color>
    <Color x:Key="Border.Subtle">#383A4A</Color>
    <Color x:Key="Border.Strong">#44475A</Color>
    <Color x:Key="Border.Divider">#1E1F29</Color>
    <Color x:Key="Text.Primary">#F8F8F2</Color>
    <Color x:Key="Text.Secondary">#BFBFB8</Color>
    <Color x:Key="Text.Tertiary">#6272A4</Color>
    <Color x:Key="Text.Disabled">#44475A</Color>
    <Color x:Key="Text.Inverse">#282A36</Color>
    <Color x:Key="Accent.Primary">#BD93F9</Color>
    <Color x:Key="Accent.Hover">#D2B0FF</Color>
    <Color x:Key="Accent.Active">#9F7AD9</Color>
    <Color x:Key="Accent.Subtle">#44475A</Color>
    <Color x:Key="Status.Success">#50FA7B</Color>
    <Color x:Key="Status.Success.Subtle">#2F4530</Color>
    <Color x:Key="Status.Warning">#F1FA8C</Color>
    <Color x:Key="Status.Warning.Subtle">#4A4B22</Color>
    <Color x:Key="Status.Error">#FF5555</Color>
    <Color x:Key="Status.Error.Subtle">#4F2828</Color>
    <Color x:Key="Status.Info">#8BE9FD</Color>
    <Color x:Key="Mono.Bg">#1E1F29</Color>
    <Color x:Key="Mono.Text">#F8F8F2</Color>
    <Color x:Key="Mono.Dim">#6272A4</Color>
    <Color x:Key="Chrome.Bg">#1E1F29</Color>
    <Color x:Key="Chrome.Border">#383A4A</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#282A36"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#2D2F3F"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#383A4A"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#44475A"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#4E5168"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#44475A"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#282A36"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#383A4A"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#44475A"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#1E1F29"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#BD93F9"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#F8F8F2"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#BFBFB8"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#6272A4"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#44475A"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#282A36"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#BD93F9"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#D2B0FF"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#9F7AD9"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#44475A"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#50FA7B"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#2F4530"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#F1FA8C"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#4A4B22"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#FF5555"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#4F2828"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#8BE9FD"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#1E1F29"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#F8F8F2"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#6272A4"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#1E1F29"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#383A4A"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#1E1F29"/>
        <GradientStop Offset="1" Color="#282A36"/>
    </LinearGradientBrush>

</ResourceDictionary>
