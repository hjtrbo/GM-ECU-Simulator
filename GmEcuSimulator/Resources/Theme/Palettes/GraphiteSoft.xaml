<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        GRAPHITE-SOFT  -  test variant of Graphite.
        Identical to Graphite except Text.Primary and Mono.Text are dropped
        from near-white to a soft grey. Reduces eye-strain on the deepest
        Bg.Base / Mono.Bg surfaces; lighter interactive surfaces
        (buttons / Bg.Hover etc.) keep the same brush so their contrast
        ratio is unchanged. Compare side-by-side with Graphite to decide.
    -->

    <Color x:Key="Bg.Base">#161616</Color>
    <Color x:Key="Bg.Surface">#1F1F1F</Color>
    <Color x:Key="Bg.Elevated">#2A2A2A</Color>
    <Color x:Key="Bg.Hover">#353535</Color>
    <Color x:Key="Bg.Active">#404040</Color>
    <Color x:Key="Bg.Selected">#2C3F3A</Color>
    <Color x:Key="Bg.Disabled">#222222</Color>
    <Color x:Key="Border.Subtle">#2D2D2D</Color>
    <Color x:Key="Border.Strong">#454545</Color>
    <Color x:Key="Border.Divider">#1F1F1F</Color>
    <Color x:Key="Text.Primary">#C7C7C7</Color>
    <Color x:Key="Text.Secondary">#ABABAB</Color>
    <Color x:Key="Text.Tertiary">#767676</Color>
    <Color x:Key="Text.Disabled">#525252</Color>
    <Color x:Key="Text.Inverse">#0E0E0E</Color>
    <Color x:Key="Accent.Primary">#3DAE9A</Color>
    <Color x:Key="Accent.Hover">#56C2AE</Color>
    <Color x:Key="Accent.Active">#2E8E7E</Color>
    <Color x:Key="Accent.Subtle">#1E3934</Color>
    <Color x:Key="Status.Success">#67C58E</Color>
    <Color x:Key="Status.Success.Subtle">#1F3A2A</Color>
    <Color x:Key="Status.Warning">#E5AE3F</Color>
    <Color x:Key="Status.Warning.Subtle">#3A2F1B</Color>
    <Color x:Key="Status.Error">#E26060</Color>
    <Color x:Key="Status.Error.Subtle">#3A2222</Color>
    <Color x:Key="Status.Info">#3DAE9A</Color>
    <Color x:Key="Mono.Bg">#101010</Color>
    <Color x:Key="Mono.Text">#B6B6B6</Color>
    <Color x:Key="Mono.Dim">#767676</Color>
    <Color x:Key="Chrome.Bg">#0F0F0F</Color>
    <Color x:Key="Chrome.Border">#2D2D2D</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#161616"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#1F1F1F"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#353535"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#404040"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#2C3F3A"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#222222"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#454545"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#1F1F1F"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#3DAE9A"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#C7C7C7"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#ABABAB"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#767676"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#525252"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#0E0E0E"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#3DAE9A"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#56C2AE"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#2E8E7E"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#1E3934"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#67C58E"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#1F3A2A"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#E5AE3F"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#3A2F1B"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#E26060"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#3A2222"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#3DAE9A"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#101010"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#B6B6B6"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#767676"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#0F0F0F"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#2D2D2D"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0F0F0F"/>
        <GradientStop Offset="1" Color="#161616"/>
    </LinearGradientBrush>

</ResourceDictionary>
