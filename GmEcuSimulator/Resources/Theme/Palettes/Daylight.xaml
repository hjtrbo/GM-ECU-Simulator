<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DAYLIGHT  -  clean light theme.
        Off-white canvas with a darker GM-blue accent (#1E68C8) for AA
        contrast on white. For projector / training-room use, or anyone
        who prefers light themes during daytime work.
    -->

    <Color x:Key="Bg.Base">#FAFAFA</Color>
    <Color x:Key="Bg.Surface">#FFFFFF</Color>
    <Color x:Key="Bg.Elevated">#F4F4F6</Color>
    <Color x:Key="Bg.Hover">#ECECF0</Color>
    <Color x:Key="Bg.Active">#DDDFE6</Color>
    <Color x:Key="Bg.Selected">#DCE9FB</Color>
    <Color x:Key="Bg.Disabled">#F0F0F2</Color>
    <Color x:Key="Border.Subtle">#E5E5E9</Color>
    <Color x:Key="Border.Strong">#CACEDB</Color>
    <Color x:Key="Border.Divider">#EDEEF2</Color>
    <Color x:Key="Text.Primary">#14171F</Color>
    <Color x:Key="Text.Secondary">#4A4F60</Color>
    <Color x:Key="Text.Tertiary">#777E92</Color>
    <Color x:Key="Text.Disabled">#B5BAC8</Color>
    <Color x:Key="Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Accent.Primary">#1E68C8</Color>
    <Color x:Key="Accent.Hover">#2D80E6</Color>
    <Color x:Key="Accent.Active">#1854A6</Color>
    <Color x:Key="Accent.Subtle">#CFE0F7</Color>
    <Color x:Key="Accent.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Status.Success">#1E9E5E</Color>
    <Color x:Key="Status.Success.Subtle">#D8F0E2</Color>
    <Color x:Key="Status.Warning">#B27B0E</Color>
    <Color x:Key="Status.Warning.Subtle">#FAEFD1</Color>
    <Color x:Key="Status.Error">#C53939</Color>
    <Color x:Key="Status.Error.Subtle">#F8D7D7</Color>
    <Color x:Key="Status.Info">#1E68C8</Color>
    <Color x:Key="Mono.Bg">#F4F4F6</Color>
    <Color x:Key="Mono.Text">#14171F</Color>
    <Color x:Key="Mono.Dim">#777E92</Color>
    <Color x:Key="Chrome.Bg">#F0F0F2</Color>
    <Color x:Key="Chrome.Border">#E5E5E9</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#F4F4F6"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#ECECF0"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#DDDFE6"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#DCE9FB"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#F0F0F2"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#E5E5E9"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#CACEDB"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#EDEEF2"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#1E68C8"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#14171F"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#4A4F60"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#777E92"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#B5BAC8"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#1E68C8"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#2D80E6"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#1854A6"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#CFE0F7"/>
    <SolidColorBrush x:Key="Accent.OnPrimaryBrush"   Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#1E9E5E"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#D8F0E2"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#B27B0E"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#FAEFD1"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#C53939"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#F8D7D7"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#1E68C8"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#F4F4F6"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#14171F"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#777E92"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#F0F0F2"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#E5E5E9"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F0F0F2"/>
        <GradientStop Offset="1" Color="#FAFAFA"/>
    </LinearGradientBrush>

</ResourceDictionary>
