<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        SLATE  -  mid-tone steel-grey.
        Lighter than Midnight, cooler than Graphite. Steel-blue accent. A
        comfortable middle ground for users who find true dark themes too
        contrasty under fluorescent office light.
    -->

    <Color x:Key="Bg.Base">#3A4252</Color>
    <Color x:Key="Bg.Surface">#434B5C</Color>
    <Color x:Key="Bg.Elevated">#4D556A</Color>
    <Color x:Key="Bg.Hover">#5A6377</Color>
    <Color x:Key="Bg.Active">#677085</Color>
    <Color x:Key="Bg.Selected">#3F567A</Color>
    <Color x:Key="Bg.Disabled">#3A4252</Color>
    <Color x:Key="Border.Subtle">#4F586D</Color>
    <Color x:Key="Border.Strong">#677085</Color>
    <Color x:Key="Border.Divider">#333A48</Color>
    <Color x:Key="Text.Primary">#EAEDF3</Color>
    <Color x:Key="Text.Secondary">#A8B0BF</Color>
    <Color x:Key="Text.Tertiary">#787F8E</Color>
    <Color x:Key="Text.Disabled">#5A6273</Color>
    <Color x:Key="Text.Inverse">#1F232C</Color>
    <Color x:Key="Accent.Primary">#5E9CE6</Color>
    <Color x:Key="Accent.Hover">#7AAFEC</Color>
    <Color x:Key="Accent.Active">#4582CC</Color>
    <Color x:Key="Accent.Subtle">#324A6B</Color>
    <Color x:Key="Status.Success">#67C088</Color>
    <Color x:Key="Status.Success.Subtle">#2E4636</Color>
    <Color x:Key="Status.Warning">#E5B548</Color>
    <Color x:Key="Status.Warning.Subtle">#453B22</Color>
    <Color x:Key="Status.Error">#E66464</Color>
    <Color x:Key="Status.Error.Subtle">#45282C</Color>
    <Color x:Key="Status.Info">#5E9CE6</Color>
    <Color x:Key="Mono.Bg">#2E3543</Color>
    <Color x:Key="Mono.Text">#CCD4E0</Color>
    <Color x:Key="Mono.Dim">#787F8E</Color>
    <Color x:Key="Chrome.Bg">#2E3543</Color>
    <Color x:Key="Chrome.Border">#4F586D</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#3A4252"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#434B5C"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#4D556A"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#5A6377"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#677085"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#3F567A"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#3A4252"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#4F586D"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#677085"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#333A48"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#5E9CE6"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#EAEDF3"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#A8B0BF"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#787F8E"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#5A6273"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#1F232C"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#5E9CE6"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#7AAFEC"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#4582CC"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#324A6B"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#67C088"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#2E4636"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#E5B548"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#453B22"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#E66464"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#45282C"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#5E9CE6"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#2E3543"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#CCD4E0"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#787F8E"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#2E3543"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#4F586D"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#2E3543"/>
        <GradientStop Offset="1" Color="#3A4252"/>
    </LinearGradientBrush>

</ResourceDictionary>
