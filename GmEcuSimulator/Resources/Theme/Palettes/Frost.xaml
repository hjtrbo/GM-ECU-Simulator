<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        FROST  -  cool pale-blue light theme.
        Slightly cooler than Daylight; takes its cue from Nord's snow
        storm palette. Crisp navy accent, slightly bluer surfaces. Good
        for high-resolution displays where Daylight's warm white can
        look yellowish.
    -->

    <Color x:Key="Bg.Base">#F5F8FB</Color>
    <Color x:Key="Bg.Surface">#FFFFFF</Color>
    <Color x:Key="Bg.Elevated">#EBF1F7</Color>
    <Color x:Key="Bg.Hover">#E0E7EE</Color>
    <Color x:Key="Bg.Active">#CDD7E1</Color>
    <Color x:Key="Bg.Selected">#CFE0F0</Color>
    <Color x:Key="Bg.Disabled">#EEF2F6</Color>
    <Color x:Key="Border.Subtle">#DCE4ED</Color>
    <Color x:Key="Border.Strong">#B6C3D2</Color>
    <Color x:Key="Border.Divider">#E6EDF3</Color>
    <Color x:Key="Text.Primary">#1B2937</Color>
    <Color x:Key="Text.Secondary">#455467</Color>
    <Color x:Key="Text.Tertiary">#728091</Color>
    <Color x:Key="Text.Disabled">#B0BAC8</Color>
    <Color x:Key="Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Accent.Primary">#1B62B8</Color>
    <Color x:Key="Accent.Hover">#2D7AD8</Color>
    <Color x:Key="Accent.Active">#144F95</Color>
    <Color x:Key="Accent.Subtle">#C9DCEF</Color>
    <Color x:Key="Accent.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Status.Success">#1E9E5E</Color>
    <Color x:Key="Status.Success.Subtle">#D8F0E2</Color>
    <Color x:Key="Status.Warning">#B27B0E</Color>
    <Color x:Key="Status.Warning.Subtle">#FAEFD1</Color>
    <Color x:Key="Status.Error">#C53939</Color>
    <Color x:Key="Status.Error.Subtle">#F8D7D7</Color>
    <Color x:Key="Status.Info">#1B62B8</Color>
    <Color x:Key="Mono.Bg">#EBF1F7</Color>
    <Color x:Key="Mono.Text">#1B2937</Color>
    <Color x:Key="Mono.Dim">#728091</Color>
    <Color x:Key="Chrome.Bg">#E0E7EE</Color>
    <Color x:Key="Chrome.Border">#DCE4ED</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#F5F8FB"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#EBF1F7"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#E0E7EE"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#CDD7E1"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#CFE0F0"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#EEF2F6"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#DCE4ED"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#B6C3D2"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#E6EDF3"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#1B62B8"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#1B2937"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#455467"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#728091"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#B0BAC8"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#1B62B8"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#2D7AD8"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#144F95"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#C9DCEF"/>
    <SolidColorBrush x:Key="Accent.OnPrimaryBrush"   Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#1E9E5E"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#D8F0E2"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#B27B0E"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#FAEFD1"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#C53939"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#F8D7D7"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#1B62B8"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#EBF1F7"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#1B2937"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#728091"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#E0E7EE"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#DCE4ED"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#E0E7EE"/>
        <GradientStop Offset="1" Color="#F5F8FB"/>
    </LinearGradientBrush>

</ResourceDictionary>
