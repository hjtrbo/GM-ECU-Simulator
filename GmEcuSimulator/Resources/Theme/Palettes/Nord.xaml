<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        NORD  -  Arctic-inspired cool dark theme.
        Direct lift of the Nord palette by Arctic Ice Studio: muted polar
        night surfaces paired with frost-teal accents. Reads quieter than
        Midnight; less contrast, more atmosphere.
    -->

    <Color x:Key="Bg.Base">#2E3440</Color>
    <Color x:Key="Bg.Surface">#3B4252</Color>
    <Color x:Key="Bg.Elevated">#434C5E</Color>
    <Color x:Key="Bg.Hover">#4C566A</Color>
    <Color x:Key="Bg.Active">#5E6779</Color>
    <Color x:Key="Bg.Selected">#4C566A</Color>
    <Color x:Key="Bg.Disabled">#2E3440</Color>
    <Color x:Key="Border.Subtle">#3B4252</Color>
    <Color x:Key="Border.Strong">#4C566A</Color>
    <Color x:Key="Border.Divider">#22262F</Color>
    <Color x:Key="Text.Primary">#ECEFF4</Color>
    <Color x:Key="Text.Secondary">#D8DEE9</Color>
    <Color x:Key="Text.Tertiary">#818896</Color>
    <Color x:Key="Text.Disabled">#4C566A</Color>
    <Color x:Key="Text.Inverse">#2E3440</Color>
    <Color x:Key="Accent.Primary">#88C0D0</Color>
    <Color x:Key="Accent.Hover">#A6D2DF</Color>
    <Color x:Key="Accent.Active">#6FA7B8</Color>
    <Color x:Key="Accent.Subtle">#3B4252</Color>
    <Color x:Key="Status.Success">#A3BE8C</Color>
    <Color x:Key="Status.Success.Subtle">#3A4233</Color>
    <Color x:Key="Status.Warning">#EBCB8B</Color>
    <Color x:Key="Status.Warning.Subtle">#4D4533</Color>
    <Color x:Key="Status.Error">#BF616A</Color>
    <Color x:Key="Status.Error.Subtle">#482929</Color>
    <Color x:Key="Status.Info">#81A1C1</Color>
    <Color x:Key="Mono.Bg">#242933</Color>
    <Color x:Key="Mono.Text">#D8DEE9</Color>
    <Color x:Key="Mono.Dim">#818896</Color>
    <Color x:Key="Chrome.Bg">#242933</Color>
    <Color x:Key="Chrome.Border">#3B4252</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#2E3440"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#3B4252"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#434C5E"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#4C566A"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#5E6779"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#4C566A"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#2E3440"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#3B4252"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#4C566A"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#22262F"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#88C0D0"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#ECEFF4"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#D8DEE9"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#818896"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#4C566A"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#2E3440"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#88C0D0"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#A6D2DF"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#6FA7B8"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#3B4252"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#A3BE8C"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#3A4233"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#EBCB8B"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#4D4533"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#BF616A"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#482929"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#81A1C1"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#242933"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#D8DEE9"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#818896"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#242933"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#3B4252"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#242933"/>
        <GradientStop Offset="1" Color="#2E3440"/>
    </LinearGradientBrush>

</ResourceDictionary>
