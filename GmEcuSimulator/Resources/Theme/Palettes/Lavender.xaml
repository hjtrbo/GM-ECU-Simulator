<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        LAVENDER  -  soft light theme with violet accents.
        Pale-lilac canvas with deep purple primary. Warmer than Frost,
        cooler than Daylight; reads gentle without losing definition on
        text-heavy panels.
    -->

    <Color x:Key="Bg.Base">#F5F0F8</Color>
    <Color x:Key="Bg.Surface">#FFFFFF</Color>
    <Color x:Key="Bg.Elevated">#EDE5F2</Color>
    <Color x:Key="Bg.Hover">#E1D5EA</Color>
    <Color x:Key="Bg.Active">#CFC0DC</Color>
    <Color x:Key="Bg.Selected">#DCC9EB</Color>
    <Color x:Key="Bg.Disabled">#EFEAF3</Color>
    <Color x:Key="Border.Subtle">#E1D8EB</Color>
    <Color x:Key="Border.Strong">#B9ACC6</Color>
    <Color x:Key="Border.Divider">#E9E1F0</Color>
    <Color x:Key="Text.Primary">#2C2138</Color>
    <Color x:Key="Text.Secondary">#5C4F6B</Color>
    <Color x:Key="Text.Tertiary">#897D96</Color>
    <Color x:Key="Text.Disabled">#B0A5BB</Color>
    <Color x:Key="Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Accent.Primary">#7B4FB2</Color>
    <Color x:Key="Accent.Hover">#9569C8</Color>
    <Color x:Key="Accent.Active">#5E3690</Color>
    <Color x:Key="Accent.Subtle">#D6C5E5</Color>
    <Color x:Key="Status.Success">#2D9956</Color>
    <Color x:Key="Status.Success.Subtle">#DEEFE2</Color>
    <Color x:Key="Status.Warning">#B07A0E</Color>
    <Color x:Key="Status.Warning.Subtle">#F4E8C8</Color>
    <Color x:Key="Status.Error">#C03434</Color>
    <Color x:Key="Status.Error.Subtle">#F4D7D7</Color>
    <Color x:Key="Status.Info">#7B4FB2</Color>
    <Color x:Key="Mono.Bg">#EDE5F2</Color>
    <Color x:Key="Mono.Text">#2C2138</Color>
    <Color x:Key="Mono.Dim">#897D96</Color>
    <Color x:Key="Chrome.Bg">#E1D5EA</Color>
    <Color x:Key="Chrome.Border">#E1D8EB</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#F5F0F8"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#EDE5F2"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#E1D5EA"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#CFC0DC"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#DCC9EB"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#EFEAF3"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#E1D8EB"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#B9ACC6"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#E9E1F0"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#7B4FB2"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#2C2138"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#5C4F6B"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#897D96"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#B0A5BB"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#7B4FB2"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#9569C8"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#5E3690"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#D6C5E5"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#2D9956"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#DEEFE2"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#B07A0E"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#F4E8C8"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#C03434"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#F4D7D7"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#7B4FB2"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#EDE5F2"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#2C2138"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#897D96"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#E1D5EA"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#E1D8EB"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#E1D5EA"/>
        <GradientStop Offset="1" Color="#F5F0F8"/>
    </LinearGradientBrush>

</ResourceDictionary>
