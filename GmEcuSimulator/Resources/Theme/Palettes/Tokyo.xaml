<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        TOKYO  -  deep navy with electric-blue accents.
        Inspired by Tokyo Night. The deepest dark in the set; near-black
        navy surfaces with a bright cobalt accent. Use when ambient light
        is low and you want the chrome to drop out of the way.
    -->

    <Color x:Key="Bg.Base">#1A1B26</Color>
    <Color x:Key="Bg.Surface">#24283B</Color>
    <Color x:Key="Bg.Elevated">#2A2F44</Color>
    <Color x:Key="Bg.Hover">#343A52</Color>
    <Color x:Key="Bg.Active">#3B4261</Color>
    <Color x:Key="Bg.Selected">#364A82</Color>
    <Color x:Key="Bg.Disabled">#1A1B26</Color>
    <Color x:Key="Border.Subtle">#2A2F44</Color>
    <Color x:Key="Border.Strong">#3B4261</Color>
    <Color x:Key="Border.Divider">#15161E</Color>
    <Color x:Key="Text.Primary">#C0CAF5</Color>
    <Color x:Key="Text.Secondary">#9AA5CE</Color>
    <Color x:Key="Text.Tertiary">#565F89</Color>
    <Color x:Key="Text.Disabled">#414868</Color>
    <Color x:Key="Text.Inverse">#1A1B26</Color>
    <Color x:Key="Accent.Primary">#7AA2F7</Color>
    <Color x:Key="Accent.Hover">#93B5F9</Color>
    <Color x:Key="Accent.Active">#5481D8</Color>
    <Color x:Key="Accent.Subtle">#2D3653</Color>
    <Color x:Key="Accent.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Status.Success">#9ECE6A</Color>
    <Color x:Key="Status.Success.Subtle">#2E3A23</Color>
    <Color x:Key="Status.Warning">#E0AF68</Color>
    <Color x:Key="Status.Warning.Subtle">#4B3823</Color>
    <Color x:Key="Status.Error">#F7768E</Color>
    <Color x:Key="Status.Error.Subtle">#4D2933</Color>
    <Color x:Key="Status.Info">#7DCFFF</Color>
    <Color x:Key="Mono.Bg">#15161E</Color>
    <Color x:Key="Mono.Text">#C0CAF5</Color>
    <Color x:Key="Mono.Dim">#565F89</Color>
    <Color x:Key="Chrome.Bg">#15161E</Color>
    <Color x:Key="Chrome.Border">#2A2F44</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#1A1B26"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#24283B"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#2A2F44"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#343A52"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#3B4261"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#364A82"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#1A1B26"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#2A2F44"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#3B4261"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#15161E"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#7AA2F7"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#C0CAF5"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#9AA5CE"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#565F89"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#414868"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#1A1B26"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#7AA2F7"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#93B5F9"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#5481D8"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#2D3653"/>
    <SolidColorBrush x:Key="Accent.OnPrimaryBrush"   Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#9ECE6A"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#2E3A23"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#E0AF68"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#4B3823"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#F7768E"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#4D2933"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#7DCFFF"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#15161E"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#C0CAF5"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#565F89"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#15161E"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#2A2F44"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#15161E"/>
        <GradientStop Offset="1" Color="#1A1B26"/>
    </LinearGradientBrush>

</ResourceDictionary>
