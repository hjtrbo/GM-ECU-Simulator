<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        PAPER  -  warm sepia light theme.
        Off-white canvas with a sienna-brown accent. Reads like a printed
        page; reduced blue light. The warm counterpart to Daylight.
    -->

    <Color x:Key="Bg.Base">#F7F2E9</Color>
    <Color x:Key="Bg.Surface">#FFFCF5</Color>
    <Color x:Key="Bg.Elevated">#F1EAD9</Color>
    <Color x:Key="Bg.Hover">#EAE2CE</Color>
    <Color x:Key="Bg.Active">#D9CFB5</Color>
    <Color x:Key="Bg.Selected">#F0E2BC</Color>
    <Color x:Key="Bg.Disabled">#EFEADC</Color>
    <Color x:Key="Border.Subtle">#E4DBC4</Color>
    <Color x:Key="Border.Strong">#C6BC9F</Color>
    <Color x:Key="Border.Divider">#EDE5D0</Color>
    <Color x:Key="Text.Primary">#2D2820</Color>
    <Color x:Key="Text.Secondary">#5A5040</Color>
    <Color x:Key="Text.Tertiary">#897D69</Color>
    <Color x:Key="Text.Disabled">#B0A893</Color>
    <Color x:Key="Text.Inverse">#FFFCF5</Color>
    <Color x:Key="Accent.Primary">#A06824</Color>
    <Color x:Key="Accent.Hover">#BB7E36</Color>
    <Color x:Key="Accent.Active">#855218</Color>
    <Color x:Key="Accent.Subtle">#E8D5B5</Color>
    <Color x:Key="Status.Success">#4A8E37</Color>
    <Color x:Key="Status.Success.Subtle">#D8E8C8</Color>
    <Color x:Key="Status.Warning">#B27B0E</Color>
    <Color x:Key="Status.Warning.Subtle">#F0E4C0</Color>
    <Color x:Key="Status.Error">#C03434</Color>
    <Color x:Key="Status.Error.Subtle">#F0D2D2</Color>
    <Color x:Key="Status.Info">#A06824</Color>
    <Color x:Key="Mono.Bg">#F1EAD9</Color>
    <Color x:Key="Mono.Text">#2D2820</Color>
    <Color x:Key="Mono.Dim">#897D69</Color>
    <Color x:Key="Chrome.Bg">#EAE2CE</Color>
    <Color x:Key="Chrome.Border">#E4DBC4</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#F7F2E9"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#FFFCF5"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#F1EAD9"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#EAE2CE"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#D9CFB5"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#F0E2BC"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#EFEADC"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#E4DBC4"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#C6BC9F"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#EDE5D0"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#A06824"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#2D2820"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#5A5040"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#897D69"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#B0A893"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#FFFCF5"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#A06824"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#BB7E36"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#855218"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#E8D5B5"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#4A8E37"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#D8E8C8"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#B27B0E"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#F0E4C0"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#C03434"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#F0D2D2"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#A06824"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#F1EAD9"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#2D2820"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#897D69"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#EAE2CE"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#E4DBC4"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#EAE2CE"/>
        <GradientStop Offset="1" Color="#F7F2E9"/>
    </LinearGradientBrush>

</ResourceDictionary>
