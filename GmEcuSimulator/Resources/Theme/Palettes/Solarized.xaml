<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        SOLARIZED DARK  -  Ethan Schoonover's classic.
        Warm cyan-teal base, low chromatic contrast, deliberately
        muted - eyes don't fatigue under it. Status / accent colours come
        straight from the Solarized accent set so semantics stay legible.
        Reference: https://ethanschoonover.com/solarized/
    -->

    <Color x:Key="Bg.Base">#002B36</Color>
    <Color x:Key="Bg.Surface">#073642</Color>
    <Color x:Key="Bg.Elevated">#094753</Color>
    <Color x:Key="Bg.Hover">#0F5868</Color>
    <Color x:Key="Bg.Active">#156A7E</Color>
    <Color x:Key="Bg.Selected">#0F4855</Color>
    <Color x:Key="Bg.Disabled">#033A47</Color>
    <Color x:Key="Border.Subtle">#0F4855</Color>
    <Color x:Key="Border.Strong">#1F6072</Color>
    <Color x:Key="Border.Divider">#053541</Color>
    <Color x:Key="Text.Primary">#93A1A1</Color>
    <Color x:Key="Text.Secondary">#839496</Color>
    <Color x:Key="Text.Tertiary">#586E75</Color>
    <Color x:Key="Text.Disabled">#3F555C</Color>
    <Color x:Key="Text.Inverse">#002B36</Color>
    <Color x:Key="Accent.Primary">#268BD2</Color>
    <Color x:Key="Accent.Hover">#4AA0DC</Color>
    <Color x:Key="Accent.Active">#1A7AB8</Color>
    <Color x:Key="Accent.Subtle">#0F3E5A</Color>
    <Color x:Key="Accent.OnPrimary">#FFFFFF</Color>
    <Color x:Key="Status.Success">#859900</Color>
    <Color x:Key="Status.Success.Subtle">#1F2B0F</Color>
    <Color x:Key="Status.Warning">#B58900</Color>
    <Color x:Key="Status.Warning.Subtle">#2D2410</Color>
    <Color x:Key="Status.Error">#DC322F</Color>
    <Color x:Key="Status.Error.Subtle">#3A1818</Color>
    <Color x:Key="Status.Info">#2AA198</Color>
    <Color x:Key="Mono.Bg">#001F27</Color>
    <Color x:Key="Mono.Text">#93A1A1</Color>
    <Color x:Key="Mono.Dim">#586E75</Color>
    <Color x:Key="Chrome.Bg">#001F27</Color>
    <Color x:Key="Chrome.Border">#0F4855</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#002B36"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#073642"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#094753"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#0F5868"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#156A7E"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#0F4855"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#033A47"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#0F4855"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#1F6072"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#053541"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#268BD2"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#93A1A1"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#839496"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#586E75"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#3F555C"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#002B36"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#268BD2"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#4AA0DC"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#1A7AB8"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#0F3E5A"/>
    <SolidColorBrush x:Key="Accent.OnPrimaryBrush"   Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#859900"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#1F2B0F"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#B58900"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#2D2410"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#DC322F"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#3A1818"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#2AA198"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#001F27"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#93A1A1"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#586E75"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#001F27"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#0F4855"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#001F27"/>
        <GradientStop Offset="1" Color="#002B36"/>
    </LinearGradientBrush>

</ResourceDictionary>
