<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        FOREST  -  mid-tone green-tinted dark.
        Reads as "engineering-station green" - the muted chlorophyll cast
        common on certain Tek and HP test gear. Lighter than the cool
        darks; gives status colours a fresh contrast.
    -->

    <Color x:Key="Bg.Base">#2F3A2D</Color>
    <Color x:Key="Bg.Surface">#374435</Color>
    <Color x:Key="Bg.Elevated">#40503E</Color>
    <Color x:Key="Bg.Hover">#4D604A</Color>
    <Color x:Key="Bg.Active">#586E56</Color>
    <Color x:Key="Bg.Selected">#365F3D</Color>
    <Color x:Key="Bg.Disabled">#2F3A2D</Color>
    <Color x:Key="Border.Subtle">#42523F</Color>
    <Color x:Key="Border.Strong">#586E56</Color>
    <Color x:Key="Border.Divider">#263026</Color>
    <Color x:Key="Text.Primary">#E6EDE0</Color>
    <Color x:Key="Text.Secondary">#A2AF9D</Color>
    <Color x:Key="Text.Tertiary">#727F6F</Color>
    <Color x:Key="Text.Disabled">#4F5A4C</Color>
    <Color x:Key="Text.Inverse">#1A2218</Color>
    <Color x:Key="Accent.Primary">#7DC57E</Color>
    <Color x:Key="Accent.Hover">#95D396</Color>
    <Color x:Key="Accent.Active">#5BA75D</Color>
    <Color x:Key="Accent.Subtle">#2F4E33</Color>
    <Color x:Key="Status.Success">#7DC57E</Color>
    <Color x:Key="Status.Success.Subtle">#2C3F2B</Color>
    <Color x:Key="Status.Warning">#E0B43E</Color>
    <Color x:Key="Status.Warning.Subtle">#403721</Color>
    <Color x:Key="Status.Error">#E36161</Color>
    <Color x:Key="Status.Error.Subtle">#402626</Color>
    <Color x:Key="Status.Info">#7DC57E</Color>
    <Color x:Key="Mono.Bg">#222B21</Color>
    <Color x:Key="Mono.Text">#C8D2C3</Color>
    <Color x:Key="Mono.Dim">#727F6F</Color>
    <Color x:Key="Chrome.Bg">#222B21</Color>
    <Color x:Key="Chrome.Border">#42523F</Color>

    <SolidColorBrush x:Key="Bg.BaseBrush"      Color="#2F3A2D"/>
    <SolidColorBrush x:Key="Bg.SurfaceBrush"   Color="#374435"/>
    <SolidColorBrush x:Key="Bg.ElevatedBrush"  Color="#40503E"/>
    <SolidColorBrush x:Key="Bg.HoverBrush"     Color="#4D604A"/>
    <SolidColorBrush x:Key="Bg.ActiveBrush"    Color="#586E56"/>
    <SolidColorBrush x:Key="Bg.SelectedBrush"  Color="#365F3D"/>
    <SolidColorBrush x:Key="Bg.DisabledBrush"  Color="#2F3A2D"/>

    <SolidColorBrush x:Key="Border.SubtleBrush"   Color="#42523F"/>
    <SolidColorBrush x:Key="Border.StrongBrush"   Color="#586E56"/>
    <SolidColorBrush x:Key="Border.DividerBrush"  Color="#263026"/>
    <SolidColorBrush x:Key="Border.FocusBrush"    Color="#7DC57E"/>

    <SolidColorBrush x:Key="Text.PrimaryBrush"    Color="#E6EDE0"/>
    <SolidColorBrush x:Key="Text.SecondaryBrush"  Color="#A2AF9D"/>
    <SolidColorBrush x:Key="Text.TertiaryBrush"   Color="#727F6F"/>
    <SolidColorBrush x:Key="Text.DisabledBrush"   Color="#4F5A4C"/>
    <SolidColorBrush x:Key="Text.InverseBrush"    Color="#1A2218"/>

    <SolidColorBrush x:Key="Accent.PrimaryBrush"  Color="#7DC57E"/>
    <SolidColorBrush x:Key="Accent.HoverBrush"    Color="#95D396"/>
    <SolidColorBrush x:Key="Accent.ActiveBrush"   Color="#5BA75D"/>
    <SolidColorBrush x:Key="Accent.SubtleBrush"   Color="#2F4E33"/>

    <SolidColorBrush x:Key="Status.SuccessBrush"         Color="#7DC57E"/>
    <SolidColorBrush x:Key="Status.SuccessSubtleBrush"   Color="#2C3F2B"/>
    <SolidColorBrush x:Key="Status.WarningBrush"         Color="#E0B43E"/>
    <SolidColorBrush x:Key="Status.WarningSubtleBrush"   Color="#403721"/>
    <SolidColorBrush x:Key="Status.ErrorBrush"           Color="#E36161"/>
    <SolidColorBrush x:Key="Status.ErrorSubtleBrush"     Color="#402626"/>
    <SolidColorBrush x:Key="Status.InfoBrush"            Color="#7DC57E"/>

    <SolidColorBrush x:Key="Mono.BgBrush"    Color="#222B21"/>
    <SolidColorBrush x:Key="Mono.TextBrush"  Color="#C8D2C3"/>
    <SolidColorBrush x:Key="Mono.DimBrush"   Color="#727F6F"/>

    <SolidColorBrush x:Key="Chrome.BgBrush"      Color="#222B21"/>
    <SolidColorBrush x:Key="Chrome.BorderBrush"  Color="#42523F"/>

    <LinearGradientBrush x:Key="Chrome.GradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#222B21"/>
        <GradientStop Offset="1" Color="#2F3A2D"/>
    </LinearGradientBrush>

</ResourceDictionary>
