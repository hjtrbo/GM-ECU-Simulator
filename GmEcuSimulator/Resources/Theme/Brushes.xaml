<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Brushes.xaml is the stable indirection between control styles and
        whatever palette is currently active. It merges ONE palette file
        (the default startup palette) and re-exports its brushes.

        At runtime, ThemeManager.Apply does NOT swap this merge - instead
        it mutates the live brush instances in place (SolidColorBrush.Color
        is a DependencyProperty, so every templated control re-renders
        without a parse-time re-merge). This keeps every {StaticResource ...}
        reference in control templates working as-is.

        To add a new palette, drop a new .xaml under Theme/Palettes/ that
        declares the same key set, then register its name in
        ThemeManager.AvailablePalettes.
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Theme/Palettes/Midnight.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
